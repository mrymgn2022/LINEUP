/* ---------- Formations: 11 slots {role,x,y} (x:0-100 leftвҶ’right, y:0 иҮӘйҷЈвҶ’100 ж•өйҷЈ) ---------- */
const FORM={
"4-3-3":[["GK",50,13],["RB",82,26],["CB",63,22],["CB",37,22],["LB",18,26],["CM",68,52],["CM",50,46],["CM",32,52],["RW",80,78],["ST",50,85],["LW",20,78]],
"4-4-2":[["GK",50,13],["RB",82,26],["CB",63,22],["CB",37,22],["LB",18,26],["RM",82,54],["CM",60,50],["CM",40,50],["LM",18,54],["ST",62,83],["ST",38,83]],
"4-2-3-1":[["GK",50,13],["RB",82,26],["CB",63,22],["CB",37,22],["LB",18,26],["CDM",62,44],["CDM",38,44],["RW",82,67],["CAM",50,63],["LW",18,67],["ST",50,87]],
"3-5-2":[["GK",50,13],["CB",72,22],["CB",50,20],["CB",28,22],["RWB",89,48],["CM",64,52],["CM",50,46],["CM",36,52],["LWB",11,48],["ST",62,83],["ST",38,83]],
"3-4-3":[["GK",50,13],["CB",72,22],["CB",50,20],["CB",28,22],["RM",85,50],["CM",60,48],["CM",40,48],["LM",15,50],["RW",78,81],["ST",50,85],["LW",22,81]],
"5-3-2":[["GK",50,13],["RWB",89,32],["CB",68,22],["CB",50,19],["CB",32,22],["LWB",11,32],["CM",68,55],["CM",50,50],["CM",32,55],["ST",62,83],["ST",38,83]],
"4-1-2-1-2":[["GK",50,13],["RB",82,26],["CB",63,22],["CB",37,22],["LB",18,26],["CDM",50,42],["CM",75,56],["CM",25,56],["CAM",50,68],["ST",62,85],["ST",38,85]],
"5-4-1":[["GK",50,13],["RWB",89,32],["CB",68,22],["CB",50,19],["CB",32,22],["LWB",11,32],["RM",82,57],["CM",60,53],["CM",40,53],["LM",18,57],["ST",50,85]]
};
const FORMS=Object.keys(FORM);

/* position grouping for color/filter */
const GRP={GK:"gk",RB:"df",LB:"df",CB:"df",RWB:"df",LWB:"df",CDM:"mf",CM:"mf",CAM:"mf",RM:"mf",LM:"mf",DM:"mf",AM:"mf",RW:"fw",LW:"fw",ST:"fw",CF:"fw"};
function grp(pos){return GRP[pos]||"mf"}

/* гғ”гғғгғҒеә§жЁҷ(x:0-100е·ҰвҶ’еҸі, y:0иҮӘйҷЈвҶ’100ж•өйҷЈ)гҒӢгӮүгғқгӮёгӮ·гғ§гғіеҗҚгӮ’жҺЁе®ҡ */
function roleFromXY(x,y){
  if(y<15) return 'GK';
  if(y<37){ // гғҮгӮЈгғ•гӮ§гғігӮ№гғ©гӮӨгғі
    if(x>=72) return 'RB';
    if(x<=28) return 'LB';
    return 'CB';
  }
  if(y<46){ // гӮўгғігӮ«гғјгҖңе®ҲеӮҷзҡ„MF
    if(x>=80) return 'RWB';
    if(x<=20) return 'LWB';
    return 'CDM';
  }
  if(y<62){ // дёӯзӣӨ
    if(x>=80) return 'RM';
    if(x<=20) return 'LM';
    return 'CM';
  }
  if(y<72){ // гғҲгғғгғ—дёӢ
    if(x>=78) return 'RM';
    if(x<=22) return 'LM';
    return 'CAM';
  }
  // еүҚз·ҡ
  if(x>=68) return 'RW';
  if(x<=32) return 'LW';
  return 'ST';
}

/* =========================================================
   State
   ========================================================= */
let state={formation:"4-3-3",slots:[],bench:[],photos:{},loadedClub:null,captain:null,teamName:null,teamInfo:null}; // slots: [{role,x,y,pid|null,sub|null}]
let tokenEls={};
const SIL='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M3.5 21c0-4.2 4-6.5 8.5-6.5s8.5 2.3 8.5 6.5"/></svg>';
let memFallback=null; // дҝқеӯҳгғ•гӮ©гғјгғ«гғҗгғғгӮҜ
let memPhotos=null;
const PAGE=30; // з„ЎйҷҗгӮ№гӮҜгғӯгғјгғ« 1гғҡгғјгӮёеҲҶ
let pickCurIdx=[]; // зҸҫеңЁгғ•гӮЈгғ«гӮҝгғјжёҲгҒҝйҒёжүӢгӮӨгғігғҮгғғгӮҜгӮ№пјҲpickerз”Ёпјү
let mktCurIdx=[]; // зҸҫеңЁгғ•гӮЈгғ«гӮҝгғјжёҲгҒҝйҒёжүӢгӮӨгғігғҮгғғгӮҜгӮ№пјҲеёӮе ҙз”Ёпјү
let currentSlot=-1;

function buildSlots(formKey,keepPlayers){
  const f=FORM[formKey];
  const old=state.slots;
  state.slots=f.map((s,i)=>({role:s[0],x:s[1],y:s[2],
    pid:(keepPlayers&&old[i])?old[i].pid:null,
    sub:(keepPlayers&&old[i])?(old[i].sub??null):null}));
  state.formation=formKey;
}

/* =========================================================
   Persistence (window.storage / fallback, localStorageдёҚдҪҝз”Ё)
   ========================================================= */
// дҝқеӯҳз”ЁгҒ®е®үе®ҡIDпјҡйҒёжүӢеҗҚпјӢеӣҪзұҚгӮігғјгғүгҖӮй…ҚеҲ—з•ӘеҸ·(index)гҒҢеӨүгӮҸгҒЈгҒҰгӮӮйҒёжүӢгӮ’зү№е®ҡгҒ§гҒҚгӮӢгҖӮ
function pidToKey(pid){ if(pid==null) return null; const p=P[pid]; if(!p) return null; return p[0].trim()+'|'+(p[3].trim().split(' ').pop()||''); }
let _keyMap=null;
function buildKeyMap(){ _keyMap={}; for(let i=0;i<P.length;i++){ const k=pidToKey(i); if(k!=null&&!(k in _keyMap)) _keyMap[k]=i; } }
function keyToPid(key){
  if(key==null) return null;
  if(typeof key==='number') return (key>=0&&key<P.length)?key:null; // ж—§еҪўејҸ(index)гҒ®еҫҢж–№дә’жҸӣ
  if(!_keyMap) buildKeyMap();
  return (key in _keyMap)?_keyMap[key]:null;
}
async function save(){
  const data={ v:3, formation:state.formation,
    slots:state.slots.map(s=>({role:s.role,x:s.x,y:s.y,pid:pidToKey(s.pid),sub:pidToKey(s.sub)})),
    bench:state.bench.map(pidToKey).filter(k=>k!=null),
    captain:pidToKey(state.captain),
    loadedClub:state.loadedClub,teamName:state.teamName,teamInfo:state.teamInfo };
  try{ if(window.storage){ await window.storage.set('xi_state_v2',JSON.stringify(data),false); } }catch(e){}
  memFallback=data;
}
async function savePhotos(){
  const keyed={}; for(const pid in state.photos){ const k=pidToKey(+pid); if(k!=null) keyed[k]=state.photos[pid]; }
  try{ if(window.storage){ await window.storage.set('xi_photos_v2',JSON.stringify({v:3,photos:keyed}),false); } }catch(e){}
  memPhotos=state.photos;
}
async function load(){
  let raw=null;
  try{ if(window.storage){ const r=await window.storage.get('xi_state_v2',false); if(r&&r.value) raw=JSON.parse(r.value); } }catch(e){}
  if(!raw) raw=memFallback;
  if(!raw) return null;
  if(raw.v>=3){ // гӮӯгғјеҪўејҸ вҶ’ зҸҫеңЁгҒ®indexгҒёи§ЈжұәпјҲгғҮгғјгӮҝжӣҙж–°гҒ§з•ӘеҸ·гҒҢгӮәгғ¬гҒҰгӮӮжӯЈгҒ—гҒ„йҒёжүӢгҒ«еҫ©е…ғпјү
    _keyMap=null; buildKeyMap();
    raw=Object.assign({},raw,{
      slots:(raw.slots||[]).map(s=>({role:s.role,x:s.x,y:s.y,pid:keyToPid(s.pid),sub:keyToPid(s.sub)})),
      bench:(raw.bench||[]).map(keyToPid).filter(v=>v!=null),
      captain:keyToPid(raw.captain) });
  }
  return raw;
}
async function loadPhotos(){
  let raw=null;
  try{ if(window.storage){ const r=await window.storage.get('xi_photos_v2',false); if(r&&r.value) raw=JSON.parse(r.value); } }catch(e){}
  if(!raw) return memPhotos;
  if(raw.v>=3&&raw.photos){ if(!_keyMap) buildKeyMap(); const out={}; for(const k in raw.photos){ const i=keyToPid(k); if(i!=null) out[i]=raw.photos[k]; } return out; }
  return raw; // ж—§еҪўејҸ(index-keyed)
}

/* =========================================================
   Rendering
   ========================================================= */
const pitch=document.getElementById('pitch');

/* гғҒгғјгғ иӘӯиҫјжҷӮгҒ«еҗ„гӮ№гӮҝгғЎгғіжһ гҒ®з¬¬дәҢеҖҷиЈң(slot.sub)гӮ’жҺ§гҒҲгҒӢгӮүиҮӘеӢ•гҒ§1еӣһгҒ гҒ‘еүІгӮҠеҪ“гҒҰгӮӢгҖӮ
   д»ҘеҫҢгҒҜгғҰгғјгӮ¶гғјгҒҢжүӢеӢ•гҒ§йҒёгҒігҖҒйҒёжүӢдәӨд»ЈгӮ„з§»еӢ•гҒ§гҒҜиҮӘеӢ•гҒ§еӨүгӮҸгӮүгҒӘгҒ„гҖӮ */
function autoAssignSubs(){
  if(!state.bench||!state.bench.length)return;
  const used=new Set();
  const savedRole=pickRole;
  state.slots.forEach(s=>{
    if(s.pid==null){s.sub=null;return;}
    pickRole=s.role;
    // жҺ§гҒҲгҒ®гҒҶгҒЎжңӘдҪҝз”ЁгҒ®йҒёжүӢгӮ’гҖҒгҒқгҒ®жһ гҒ®гӮөгӮёгӮ§гӮ№гғҲй ҶпјҲйҒ©жҖ§гғқгӮёгӮ·гғ§гғіе„Әе…ҲпјүгҒ§1дәә
    const avail=state.bench.filter(pid=>!inXI(pid)&&!used.has(pid)).sort(suggestSort);
    const pid=avail[0];
    // еҗҢгҒҳеӨ§жһ гҒ®жҺ§гҒҲгҒҢгҒ„гӮӢе ҙеҗҲгҒ®гҒҝз¬¬дәҢеҖҷиЈңгҒ«пјҲеӨ§жһ еӨ–гҒҫгҒ§з„ЎзҗҶгҒ«еүІгӮҠеҪ“гҒҰгҒӘгҒ„пјү
    if(pid!=null&&grp(P[pid][1])===grp(s.role)){ used.add(pid); s.sub=pid; } else s.sub=null;
  });
  pickRole=savedRole;
}
// гӮ№гӮҝгғЎгғігҒӢгӮүеӨ–гӮҢгҒҹйҒёжүӢгӮ’жҺ§гҒҲгҒ«жҲ»гҒҷпјҲгӮҜгғ©гғ–иӘӯиҫјжҷӮгҒ®гҒҝгҖӮз¬¬дәҢеҖҷиЈңгҒ«еҶҚйҒёжҠһгҒ§гҒҚгӮӢгӮҲгҒҶгҒ«пјү
function benchReturn(pid){
  if(pid==null||!state.loadedClub) return;
  if(inXI(pid)) return;
  if(!state.bench.includes(pid)) state.bench.push(pid);
}

function render(){
  // remove existing tokens
  pitch.querySelectorAll('.tok').forEach(t=>t.remove());
  tokenEls={};
  let filled=0,ages=[];
  state.slots.forEach((s,i)=>{
    const tok=document.createElement('div');
    tok.className='tok';tok.style.left=s.x+'%';tok.style.top=(100-s.y)+'%';
    tok.dataset.i=i;
    const disc=document.createElement('div');
    if(s.pid==null){
      disc.className='disc empty';disc.textContent='+';
      tok.appendChild(disc);
      const role=document.createElement('div');role.className='role';role.textContent=s.role;tok.appendChild(role);
    }else{
      const p=P[s.pid];filled++;ages.push(p[2]);
      const ph=state.photos[s.pid];
      disc.className='disc'+(ph?' photo':'');
      if(ph)disc.style.backgroundImage="url('"+ph+"')";
      let extra='';
      if(state.captain===s.pid) extra+='<span class="capt">C</span>';
      disc.innerHTML=SIL+extra;
      tok.appendChild(disc);
      const role=document.createElement('div');role.className='role';role.textContent=s.role;tok.appendChild(role);
      const nm=document.createElement('div');nm.className='pname';nm.textContent=shortName(p[0]);tok.appendChild(nm);
      // з¬¬дәҢеҖҷиЈңпјҲжүӢеӢ•гғ»ж°ёз¶ҡпјүгҖӮ"2nd"иЎЁиЁҳгҒҜгҒӣгҒҡеҲҘиүІгҒ§е°ҸгҒ•гҒҸдёӢгҒ«иЎЁзӨә
      if(s.sub!=null&&P[s.sub]){
        const sub=document.createElement('div');sub.className='psub';
        sub.textContent=shortName(P[s.sub][0]);
        tok.appendChild(sub);
      }
    }
    pitch.appendChild(tok);
    tokenEls[i]=tok;
    attachDrag(tok,i);
  });
  document.getElementById('hint').style.display=filled?'none':'block';
  document.getElementById('sAge').textContent=ages.length?(ages.reduce((a,b)=>a+b,0)/ages.length).toFixed(1):'вҖ“';
  document.getElementById('sCnt').innerHTML=filled+'<small>/11</small>';
  renderBench();
  updateTeamTag();
}
function teamDisplayName(){ return state.teamName||state.loadedClub||null; }
function updateTeamTag(){
  const el=document.getElementById('teamTag');if(!el)return;
  const name=teamDisplayName();
  if(name){ el.textContent=name; el.classList.add('team'); el.title=name; }
  else { el.textContent='tactics board'; el.classList.remove('team'); el.title=''; }
}

/* ---- гғҷгғігғҒпјҲжҺ§гҒҲпјү ---- */
function renderBench(){
  const wrap=document.getElementById('bench');
  const cue=document.getElementById('scrollcue');
  const list=state.bench.filter(pid=>!inXI(pid));
  state.bench=list; // XIгҒ«дёҠгҒҢгҒЈгҒҹйҒёжүӢгҒҜгғҷгғігғҒгҒӢгӮүйҷӨеӨ–
  if(cue)cue.style.display='block';
  const cards=list.map(pid=>{
    const p=P[pid],ph=state.photos[pid];
    return `<div class="bcard" data-pid="${pid}" draggable="false">
      <div class="bav${ph?' photo':''}" ${ph?`style="background-image:url('${ph}')"`:''}>${SIL}</div>
      <div class="bn">${shortName(p[0])}</div>
      <div class="bp">${p[1]}</div>
      <div class="bv">${p[2]}жӯі</div>
    </div>`;
  }).join('');
  const addCard=`<div class="bcard add" id="benchAdd"><div class="addplus">пјӢ</div><div class="addlbl">иҝҪеҠ </div></div>`;
  // гӮ№гӮҝгғЎгғіпјӢгғҷгғігғҒгҒ®еҗҲиЁҲдәәж•°гҒЁе№іеқҮе№ҙйҪў
  const ages=state.slots.filter(s=>s.pid!=null).map(s=>P[s.pid][2]).concat(list.map(pid=>P[pid][2]));
  const avg=ages.length?(ages.reduce((a,b)=>a+b,0)/ages.length).toFixed(1):'вҖ“';
  const xiCnt=state.slots.filter(s=>s.pid!=null).length;
  const foot=`<div class="benchfoot">еҗҲиЁҲ <b>${ages.length}</b>дәә <span>(гӮ№гӮҝгғЎгғі${xiCnt} пјӢ жҺ§гҒҲ${list.length})</span>гҖҖе№іеқҮе№ҙйҪў <b>${avg}</b><small>жӯі</small></div>`;
  const empty=list.length?'':'<div class="benchEmpty">жҺ§гҒҲйҒёжүӢгҒҢгҒ„гҒҫгҒӣгӮ“гҖӮ<b>пјӢ</b> гҒӢгӮүиҝҪеҠ гҖҒгҒҫгҒҹгҒҜдёҠгҒ® <b>в¬Ү</b> гҒ§гӮҜгғ©гғ–гӮ’иӘӯгҒҝиҫјгӮҒгҒҫгҒҷгҖӮ</div>';
  wrap.innerHTML=`<div class="bh"><b>гғҷгғігғҒ</b><span>жҺ§гҒҲ ${list.length}дәә</span><i>гғүгғ©гғғгӮ°гҒ§дәӨд»Јгғ»гӮҝгғғгғ—гҒ§и©ізҙ°</i></div>`+
    empty+`<div class="bgrid">${cards}${addCard}</div>`+foot;
  wrap.querySelectorAll('.bcard[data-pid]').forEach(card=>attachBenchDrag(card,+card.dataset.pid));
  const add=document.getElementById('benchAdd'); if(add) add.onclick=openBenchAdd;
}
/* ---- гғҷгғігғҒ вҶ’ гғ”гғғгғҒ гғүгғ©гғғгӮ°дәӨд»Ј ---- */
let dropTarget=-1;
function highlightSlot(si){
  if(si===dropTarget)return;
  if(dropTarget>=0&&tokenEls[dropTarget])tokenEls[dropTarget].classList.remove('droptarget');
  dropTarget=si;
  if(si>=0&&tokenEls[si])tokenEls[si].classList.add('droptarget');
}
function slotAtPoint(x,y){
  const r=pitch.getBoundingClientRect();
  if(x<r.left-40||x>r.right+40||y<r.top-40||y>r.bottom+40)return -1;
  let best=64,bi=-1;
  state.slots.forEach((s,i)=>{
    const cx=r.left+s.x/100*r.width, cy=r.top+(100-s.y)/100*r.height;
    const d=Math.hypot(x-cx,y-cy); if(d<best){best=d;bi=i;}
  });
  return bi;
}
function makeBenchGhost(pid){
  const ph=state.photos[pid];
  const g=document.createElement('div'); g.className='benchghost';
  g.innerHTML=`<div class="disc${ph?' photo':''}" ${ph?`style="background-image:url('${ph}')"`:''}>${SIL}</div>`;
  return g;
}
function attachBenchDrag(el,pid){
  el.style.touchAction='none';
  let sx,sy,dragging=false,ghost=null,lastX=0,lastY=0,scrollRAF=0;
  const scroller=document.getElementById('scroll');
  function paint(){
    if(!ghost)return;
    ghost.style.left=lastX+'px'; ghost.style.top=lastY+'px';
    highlightSlot(slotAtPoint(lastX,lastY));
  }
  // з”»йқўз«ҜгҒ«иҝ‘гҒҘгҒ„гҒҹгӮүиҮӘеӢ•гӮ№гӮҜгғӯгғјгғ«пјҲзёҰй•·гҒ§гӮӮеүҚз·ҡгӮ№гғӯгғғгғҲгҒҫгҒ§гғүгғ©гғғгӮ°гҒ§гҒҚгӮӢпјү
  function autoScrollTick(){
    if(!dragging){scrollRAF=0;return;}
    const vh=window.innerHeight, edge=120, max=18;
    let dy=0;
    if(lastY<edge) dy=-max*(1-lastY/edge);
    else if(lastY>vh-edge) dy=max*(1-(vh-lastY)/edge);
    if(dy){ const before=scroller.scrollTop; scroller.scrollTop+=dy; if(scroller.scrollTop!==before) paint(); }
    scrollRAF=requestAnimationFrame(autoScrollTick);
  }
  el.addEventListener('pointerdown',e=>{
    e.preventDefault(); sx=e.clientX; sy=e.clientY; dragging=false; ghost=null;
    try{el.setPointerCapture(e.pointerId);}catch(_){}
  });
  el.addEventListener('pointermove',e=>{
    if(sx===undefined)return;
    if(!dragging){
      if(Math.abs(e.clientX-sx)<6&&Math.abs(e.clientY-sy)<6)return;
      dragging=true; el.classList.add('dragging');
      ghost=makeBenchGhost(pid); document.body.appendChild(ghost);
      if(!scrollRAF) scrollRAF=requestAnimationFrame(autoScrollTick);
    }
    lastX=e.clientX; lastY=e.clientY; paint();
  });
  const end=e=>{
    if(sx===undefined)return;
    const was=dragging;
    sx=undefined; dragging=false; el.classList.remove('dragging');
    if(scrollRAF){cancelAnimationFrame(scrollRAF);scrollRAF=0;}
    if(ghost){ghost.remove();ghost=null;} highlightSlot(-1);
    try{el.releasePointerCapture(e.pointerId);}catch(_){}
    if(e.type==='pointercancel') return;          // гӮӯгғЈгғігӮ»гғ«гҒҜз„ЎиҰ–
    if(!was){ openDetail(pid,null); return; }      // еӢ•гҒӢгҒӘгҒ‘гӮҢгҒ°гӮҝгғғгғ—пјқи©ізҙ°
    const si=slotAtPoint(e.clientX,e.clientY);
    if(si>=0) benchToSlot(pid,si);
  };
  el.addEventListener('pointerup',end);
  el.addEventListener('pointercancel',end);
}
function benchToSlot(pid,slotIdx){
  const outgoing=state.slots[slotIdx].pid;
  state.slots.forEach(s=>{if(s.pid===pid)s.pid=null});
  state.slots[slotIdx].pid=pid;
  if(state.slots[slotIdx].sub===pid) state.slots[slotIdx].sub=null; // еҗҢжһ гҒ®гӮ№гӮҝгғЎгғіпјқз¬¬2еҖҷиЈңгҒ®йҮҚиӨҮгӮ’и§Јж¶Ҳ
  state.bench=state.bench.filter(b=>b!==pid);
  if(outgoing!=null&&outgoing!==pid&&!state.bench.includes(outgoing)) state.bench.push(outgoing);
  render();save();
  toast(outgoing!=null?shortName(P[pid][0])+' вҮ„ '+shortName(P[outgoing][0]):shortName(P[pid][0])+' гӮ’иө·з”Ё');
}
function initials(name){const c=name.trim().replace(/\s+$/,'').split(' ');return (c[0][0]+(c.length>1?c[c.length-1][0]:'')).toUpperCase()}
function shortName(name){const t=name.trim();const c=t.split(' ');return c.length>1?c[c.length-1]:t}

/* render formation chips */
const fbar=document.getElementById('fbar');
FORMS.forEach(f=>{
  const c=document.createElement('div');c.className='chip'+(f===state.formation?' on':'');c.textContent=f;
  c.onclick=()=>{ if(f===state.formation)return; buildSlots(f,true); [...fbar.children].forEach(x=>x.classList.remove('on')); c.classList.add('on'); render(); save(); };
  fbar.appendChild(c);
});

/* =========================================================
   Drag & tap on tokens
   ========================================================= */
function attachDrag(el,actor){
  let sx,sy,ox,oy,moved,rect;
  const base=()=>state.slots[actor];
  el.addEventListener('pointerdown',e=>{
    e.preventDefault();
    rect=pitch.getBoundingClientRect();moved=false;
    sx=e.clientX;sy=e.clientY;const b=base();ox=b.x;oy=b.y;
    el.setPointerCapture(e.pointerId);el.classList.add('drag');
  });
  el.addEventListener('pointermove',e=>{
    if(sx===undefined)return;
    if(Math.abs(e.clientX-sx)>5||Math.abs(e.clientY-sy)>5)moved=true;
    const nx=clamp(ox+(e.clientX-sx)/rect.width*100,3,97);
    const ny=clamp(oy-(e.clientY-sy)/rect.height*100,3,97);
    base().x=nx;base().y=ny;el.style.left=nx+'%';el.style.top=(100-ny)+'%';
  });
  el.addEventListener('pointerup',e=>{
    el.classList.remove('drag');
    if(sx===undefined)return;sx=undefined;
    if(!moved){ onSlotTap(actor); return; }
    let tj=-1,best=46;
    for(let j=0;j<state.slots.length;j++){
      if(j===actor)continue;
      const cx=rect.left+state.slots[j].x/100*rect.width;
      const cy=rect.top+(100-state.slots[j].y)/100*rect.height;
      const d=Math.hypot(e.clientX-cx,e.clientY-cy);
      if(d<best){best=d;tj=j;}
    }
    if(tj>=0){
      const t=state.slots[actor].pid;state.slots[actor].pid=state.slots[tj].pid;state.slots[tj].pid=t;
      state.slots[actor].x=ox;state.slots[actor].y=oy;
      render();save();toast('гғқгӮёгӮ·гғ§гғігӮ’е…ҘгӮҢжӣҝгҒҲгҒҫгҒ—гҒҹ');
    }else{
      // з©әгҒҚгӮ№гғҡгғјгӮ№гҒёз§»еӢ• вҶ’ ж–°гҒ—гҒ„дҪҚзҪ®гҒӢгӮүгғқгӮёгӮ·гғ§гғіеҗҚгӮ’иҮӘеӢ•еҲӨе®ҡ
      const s=state.slots[actor];
      const nr=roleFromXY(s.x,s.y);
      if(nr!==s.role){ s.role=nr; render(); toast('гғқгӮёгӮ·гғ§гғігӮ’ '+nr+' гҒ«еӨүжӣҙ'); }
      save();
    }
  });
  el.addEventListener('pointercancel',()=>{el.classList.remove('drag');sx=undefined;});
}
function clamp(v,a,b){return Math.max(a,Math.min(b,v))}

/* ---- йҒёжүӢеҶҷзңҹгҒ®иҝҪеҠ пјҲз«Ҝжң«еҶ…гҒ§е®Ңзөҗгғ»иҮӘеҲҶгҒ§гӮўгғғгғ—гғӯгғјгғүпјү ---- */
let photoTarget=null;
const photoInput=document.getElementById('photoInput');
function pickPhoto(pid){ photoTarget=pid; photoInput.value=''; photoInput.click(); }
photoInput.addEventListener('change',()=>{
  const f=photoInput.files&&photoInput.files[0]; if(!f||photoTarget==null)return;
  const fr=new FileReader();
  fr.onload=()=>{
    const img=new Image();
    img.onload=()=>{
      // жӯЈж–№еҪўгҒ«гғҲгғӘгғҹгғігӮ°гҒ—гҒӨгҒӨ240pxгҒёзё®е°ҸпјҲе®№йҮҸзҜҖзҙ„пјү
      const S=240,c=document.createElement('canvas');c.width=S;c.height=S;
      const ctx=c.getContext('2d');
      const side=Math.min(img.width,img.height);
      const sx=(img.width-side)/2, sy=(img.height-side)/2;
      ctx.drawImage(img,sx,sy,side,side,0,0,S,S);
      const url=c.toDataURL('image/jpeg',0.82);
      state.photos[photoTarget]=url;
      const pid=photoTarget;photoTarget=null;
      savePhotos();closeSheet();render();toast('еҶҷзңҹгӮ’иЁӯе®ҡгҒ—гҒҫгҒ—гҒҹ');
    };
    img.onerror=()=>{photoTarget=null;toast('з”»еғҸгӮ’иӘӯгҒҝиҫјгӮҒгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹ');};
    img.src=fr.result;
  };
  fr.readAsDataURL(f);
});

function onSlotTap(i){
  currentSlot=i;
  if(state.slots[i].pid==null){ openPicker(i); }
  else { openSlotMenu(i); }
}

/* =========================================================
   Sheet helpers
   ========================================================= */
const scrim=document.getElementById('scrim'),sheet=document.getElementById('sheet'),body=document.getElementById('sheetBody');
function openSheet(html){benchAddMode=false;body.innerHTML=html;body.scrollTop=0;sheet.classList.remove('expanded');sheet.style.transform='';scrim.classList.add('on');sheet.classList.add('on');}
function closeSheet(){scrim.classList.remove('on');sheet.classList.remove('on','expanded');sheet.style.transform='';}
scrim.onclick=closeSheet;

/* гӮ·гғјгғҲгҒ®гӮ№гғҜгӮӨгғ—ж“ҚдҪңпјҡдёҠгҒ§жӢЎеӨ§пјҸдёӢгҒ§й–үгҒҳгӮӢпјҲгӮ°гғ©гғ–гғҸгғігғүгғ«пјү */
(function setupSheetDrag(){
  const zone=document.getElementById('grabzone'); if(!zone)return;
  let startY=null,dy=0,dragging=false;
  zone.addEventListener('pointerdown',e=>{
    dragging=true;startY=e.clientY;dy=0;
    sheet.style.transition='none';
    try{ zone.setPointerCapture(e.pointerId); }catch(_){}
  });
  zone.addEventListener('pointermove',e=>{
    if(!dragging)return;
    dy=e.clientY-startY;
    if(dy>0){ // дёӢж–№еҗ‘пјҡжҢҮгҒ«иҝҪеҫ“
      sheet.style.transform='translateY('+dy+'px)';
    }else{ // дёҠж–№еҗ‘пјҡжӢЎеӨ§
      sheet.classList.add('expanded');
      sheet.style.transform='translateY(0)';
    }
  });
  const end=()=>{
    if(!dragging)return; dragging=false;
    sheet.style.transition='';
    sheet.style.transform='';
    if(dy>110){ closeSheet(); }                                  // еӨ§гҒҚгҒҸдёӢгҒ’гҒҹгӮүй–үгҒҳгӮӢ
    else if(dy>30){ sheet.classList.remove('expanded'); }        // е°‘гҒ—дёӢгҒ’гҒҹгӮүйҖҡеёёгӮөгӮӨгӮәгҒё
    startY=null;dy=0;
  };
  zone.addEventListener('pointerup',end);
  zone.addEventListener('pointercancel',end);
  // гғҸгғігғүгғ«гҒ®гғҖгғ–гғ«гӮҝгғғгғ—гҒ§жӢЎеӨ§вҮ”йҖҡеёёгӮ’гғҲгӮ°гғ«
  let lastTap=0;
  zone.addEventListener('click',()=>{
    const now=Date.now();
    if(now-lastTap<300){ sheet.classList.toggle('expanded'); }
    lastTap=now;
  });
})();

/* ---- Player picker (assign to slot) ---- */
// дәәж°—гӮ«гӮҰгғігғҲпјҲйҒёжүӢеҗҚ -> гӮ№гӮ«гғғгғүй…ҚзҪ®еӣһж•°пјүгҖӮе°ҶжқҘгғҗгғғгӮҜгӮЁгғігғүгҒӢгӮүдҫӣзөҰгҖӮжңӘйӣҶиЁҲжҷӮгҒҜз©әгҖӮ
let POP={};
function popScore(p){ return POP[p[0].trim()]||0; }
// гӮ№гғӯгғғгғҲеҪ№еүІгҒ”гҒЁгҒ®гӮөгӮёгӮ§гӮ№гғҲе„Әе…ҲпјҲе…Ҳй ӯгҒ»гҒ©е„Әе…ҲпјүгҖӮзӣӨйқўгғӯгғјгғ«вҶ’жҺЁи–ҰгҒҷгӮӢйҒёжүӢгғқгӮёгӮ·гғ§гғігҖӮ
const SUGGEST={
  GK:['GK'], CB:['CB'], LB:['LB'], RB:['RB'],
  LWB:['LB','LW'], RWB:['RB','RW'],
  CDM:['CDM','CM'], CM:['CM','CDM','CAM'], CAM:['CAM','CM'],
  LM:['LW','LB'], RM:['RW','RB'],
  LW:['LW','LM'], RW:['RW','RM'], ST:['ST']
};
let pickRole=null; // зҸҫеңЁгғ”гғғгӮ«гғјеҜҫиұЎгӮ№гғӯгғғгғҲгҒ®еҪ№еүІ
// еӨ§жһ еҶ…гҒ§гҒ®гғқгӮёгӮ·гғ§гғідёҰгҒій ҶпјҲеҗҢгҒҳеӨ§жһ гҒ®йҒёжүӢгӮ’гғқгӮёгӮ·гғ§гғігҒ”гҒЁгҒ«еӣәгӮҒгӮӢпјү
const POSORDER={GK:0,CB:1,RB:2,LB:3,RWB:4,LWB:5,CDM:1,CM:2,CAM:3,RM:4,LM:5,RW:1,LW:2,ST:3};
// гӮ№гғӯгғғгғҲжҢҮе®ҡгҒӘгҒ—пјҲгғҷгғігғҒиҝҪеҠ гҒӘгҒ©пјүгҒ§гҒ®гғқгӮёгӮ·гғ§гғіе…ЁдҪ“дёҰгҒій ҶпјҡGKвҶ’DFвҶ’MFвҶ’FW
const POSORDERFULL={GK:0,CB:1,RB:2,LB:3,LWB:4,RWB:5,CDM:6,CM:7,CAM:8,RM:9,LM:10,LW:11,RW:12,ST:13};
// еӨ§жһ гӮ’жҠјгҒ—гҒҹжҷӮгҒ«еҮәгӮӢзҙ°гҒӢгҒ„гғқгӮёгӮ·гғ§гғіпјҲгғҷгғігғҒиҝҪеҠ з”»йқўгҒ®гӮөгғ–гғ•гӮЈгғ«гӮҝпјү
const SUBPOS={DF:['CB','RB','LB'],MF:['CDM','CM','CAM'],FW:['ST','LW','RW']};
function suggestRank(pos){
  if(!pickRole) return 0;
  const tiers=SUGGEST[pickRole]||[pickRole];
  const i=tiers.indexOf(pos);
  if(i>=0) return i;                                   // жҳҺзӨәгӮөгӮёгӮ§гӮ№гғҲпјҲе…Ҳй ӯгҒ»гҒ©е„Әе…Ҳпјҡ0,1,2вҖҰпјү
  const sg=grp(pickRole), pg=grp(pos);
  // д»ҘйҷҚгҒҜеӨ§жһ гҒ”гҒЁгҒ«гҒҫгҒЁгӮҒгӮӢпјҡиҮӘеӨ§жһ вҶ’д»–гғ•гӮЈгғјгғ«гғүеӨ§жһ вҶ’GK(еёёгҒ«жңҖеҫҢ)гҖӮеӨ§жһ еҶ…гҒҜгғқгӮёгӮ·гғ§гғій ҶгҒ§еӣәгӮҒгӮӢгҖӮ
  const gr = pg==='gk' ? 9 : (pg===sg ? 0 : ({df:1,mf:2,fw:3})[pg]);
  return 10 + gr*10 + (POSORDER[pos]||0);
}
// гӮөгӮёгӮ§гӮ№гғҲй Ҷпјҡв‘ еҪ№еүІжҺЁи–Ұ в‘ЎгӮҜгғ©гғ–иӘӯиҫјдёӯгҒҜгҒқгҒ®гӮҜгғ©гғ–е„Әе…Ҳ в‘ўдәәж°—й Ҷ в‘Је№ҙйҪўгҒ®й«ҳгҒ„й Ҷ
function suggestSort(a,b){
  if(pickRole){ const ra=suggestRank(P[a][1]), rb=suggestRank(P[b][1]); if(ra!==rb) return ra-rb; }
  else { const oa=POSORDERFULL[P[a][1]]??99, ob=POSORDERFULL[P[b][1]]??99; if(oa!==ob) return oa-ob; } // гӮ№гғӯгғғгғҲжҢҮе®ҡгҒӘгҒ—пјҡгғқгӮёгӮ·гғ§гғій Ҷ
  const club=state.loadedClub;
  if(club){ const ca=P[a][4].trim()===club?1:0, cb=P[b][4].trim()===club?1:0; if(ca!==cb) return cb-ca; }
  const pa=popScore(P[a]), pb=popScore(P[b]);
  if(pa!==pb) return pb-pa;
  return P[b][2]-P[a][2];
}
let pickFilter={pos:'ALL',lg:'ALL',club:'ALL',q:''};
let benchAddMode=false; // гҖҢгғҷгғігғҒгҒ«иҝҪеҠ гҖҚгғ”гғғгӮ«гғјгҒӢгҒ©гҒҶгҒӢ
function openPicker(slotIdx){
  pickFilter={pos:'ALL',lg:'ALL',club:state.loadedClub||'ALL',q:''};
  const role=state.slots[slotIdx].role;
  pickRole=role;
  openSheet(pickerHTML(slotIdx,role));
  wirePicker(slotIdx);
}
function pickerHTML(slotIdx,role){
  return `
  <h2>йҒёжүӢгӮ’й…ҚзҪ® <span>${role}</span></h2>
  <div class="controls">
    <input class="search" id="pq" placeholder="йҒёжүӢеҗҚгӮ’жӨңзҙўвҖҰ" autocomplete="off">
    <div class="filters" id="posF">${posChips()}</div>
    <div class="filters" id="lgF">${lgChips()}</div>
    <div class="filters" id="clubF">${clubChips()}</div>
  </div>
  <div class="list" id="plist"></div>`;
}
function posChips(f=pickFilter){
  const opts=[["ALL","е…ЁйғЁ"],["GK","GK"],["DF","DF"],["MF","MF"],["FW","FW"]];
  let html=opts.map(o=>`<div class="fchip ${f.pos===o[0]?'on':''}" data-pos="${o[0]}">${o[1]}</div>`).join('');
  if(benchAddMode){ // гғҷгғігғҒиҝҪеҠ жҷӮпјҡеӨ§жһ гӮ’йҒёгҒ¶гҒЁеҸіеҒҙгҒ«зҙ°гҒӢгҒ„гғқгӮёгӮ·гғ§гғігҒ®гӮөгғ–гғ•гӮЈгғ«гӮҝгӮ’еҮәгҒҷ
    const subs=SUBPOS[f.pos];
    if(subs){ html+=`<div class="fchipdiv"></div>`+subs.map(sp=>`<div class="fchip subchip ${f.subpos===sp?'on':''}" data-subpos="${sp}">${sp}</div>`).join(''); }
  }
  return html;
}
function lgChips(f=pickFilter){
  const opts=[["ALL","е…ЁгғӘгғјгӮ°"],["PL","гғ—гғ¬гғҹгӮў"],["LL","гғ©гғ»гғӘгғјгӮ¬"],["SA","гӮ»гғӘгӮЁA"],["BL","гғ–гғігғҮгӮ№"],["L1","гғӘгғјгӮ°гғ»гӮўгғі"]];
  return opts.map(o=>`<div class="fchip ${f.lg===o[0]?'on':''}" data-lg="${o[0]}">${o[1]}</div>`).join('');
}
function clubChips(f=pickFilter){
  const clubs=f.lg==='ALL'
    ?[...new Set(P.map(p=>p[4].trim()))].sort()
    :[...new Set(P.filter(p=>p[5]===f.lg).map(p=>p[4].trim()))].sort();
  return `<div class="fchip ${f.club==='ALL'?'on':''}" data-club="ALL">е…ЁгӮҜгғ©гғ–</div>`+
    clubs.map(c=>`<div class="fchip ${f.club===c?'on':''}" data-club="${c}">${c}</div>`).join('');
}
function wirePicker(slotIdx){
  const q=document.getElementById('pq');
  if(q) q.oninput=()=>{pickFilter.q=q.value.toLowerCase();drawPickList(slotIdx)};
  const posF=document.getElementById('posF');
  if(posF) posF.onclick=e=>{
    const c=e.target.closest('[data-pos],[data-subpos]');if(!c)return;
    if(c.dataset.subpos!==undefined){ pickFilter.subpos=(pickFilter.subpos===c.dataset.subpos?null:c.dataset.subpos); }
    else { pickFilter.pos=c.dataset.pos; pickFilter.subpos=null; }
    posF.innerHTML=posChips(); drawPickList(slotIdx);
  };
  const lgF=document.getElementById('lgF');
  if(lgF) lgF.onclick=e=>{const c=e.target.closest('[data-lg]');if(!c)return;pickFilter.lg=c.dataset.lg;pickFilter.club='ALL';[...c.parentNode.children].forEach(x=>x.classList.remove('on'));c.classList.add('on');const cf=document.getElementById('clubF');if(cf)cf.innerHTML=clubChips();wirePickClub(slotIdx);drawPickList(slotIdx)};
  wirePickClub(slotIdx);
  drawPickList(slotIdx);
}
function wirePickClub(slotIdx){
  const clubF=document.getElementById('clubF');
  if(!clubF)return;
  clubF.onclick=e=>{const c=e.target.closest('[data-club]');if(!c)return;pickFilter.club=c.dataset.club;[...c.parentNode.children].forEach(x=>x.classList.remove('on'));c.classList.add('on');drawPickList(slotIdx);};
}
function playerMatches(p){
  if(pickFilter.lg!=='ALL'&&p[5]!==pickFilter.lg)return false;
  if(pickFilter.subpos){ if(p[1]!==pickFilter.subpos)return false; }
  else if(pickFilter.pos!=='ALL'&&grp(p[1]).toUpperCase()!==pickFilter.pos)return false;
  if(pickFilter.club!=='ALL'&&p[4].trim()!==pickFilter.club)return false;
  if(pickFilter.q&&!(p[0].toLowerCase().includes(pickFilter.q)||p[4].toLowerCase().includes(pickFilter.q)))return false;
  return true;
}
function inXI(pid){return state.slots.some(s=>s.pid===pid)}
function drawPickList(slotIdx){
  const list=document.getElementById('plist');if(!list)return;
  pickCurIdx=P.map((p,i)=>i).filter(i=>playerMatches(P[i])&&(!benchAddMode||(!inXI(i)&&!state.bench.includes(i))));
  pickCurIdx.sort(suggestSort);
  if(!pickCurIdx.length){list.innerHTML='<div class="empty-msg">и©ІеҪ“гҒҷгӮӢйҒёжүӢгҒҢгҒ„гҒҫгҒӣгӮ“</div>';return;}
  list.innerHTML=pickCurIdx.slice(0,PAGE).map(i=>prowHTML(i)).join('');
  if(pickCurIdx.length>PAGE) list.insertAdjacentHTML('beforeend',`<div class="loadmore" id="pickMore">в–ҫ гҒ•гӮүгҒ« ${pickCurIdx.length-PAGE}дәә</div>`);
  list._loaded=Math.min(PAGE,pickCurIdx.length);
  list.onscroll=()=>{
    if(list.scrollTop+list.clientHeight>=list.scrollHeight-80){
      const start=list._loaded;if(start>=pickCurIdx.length)return;
      const more=pickCurIdx.slice(start,start+PAGE);
      const s=document.getElementById('pickMore');
      if(s)s.insertAdjacentHTML('beforebegin',more.map(i=>prowHTML(i)).join(''));
      list._loaded=start+more.length;
      const ns=document.getElementById('pickMore');
      if(ns){const rem=pickCurIdx.length-list._loaded;if(rem<=0)ns.remove();else ns.textContent='в–ҫ гҒ•гӮүгҒ« '+rem+'дәә';}
    }
  };
  list.onclick=e=>{const row=e.target.closest('[data-pid]');if(!row)return;const pid=+row.dataset.pid;if(benchAddMode)addPlayerToBench(pid);else assign(slotIdx,pid);};
}
// гғҷгғігғҒгҒ«иҝҪеҠ пјҲиӘӯиҫјгӮҜгғ©гғ–гӮ’гғқгӮёгӮ·гғ§гғій ҶгҒ§е„Әе…ҲиЎЁзӨәпјү
function openBenchAdd(){
  pickFilter={pos:'ALL',lg:'ALL',club:state.loadedClub||'ALL',q:''};
  pickRole=null;
  openSheet(`
  <h2>гғҷгғігғҒгҒ«иҝҪеҠ </h2>
  <div class="controls">
    <input class="search" id="pq" placeholder="йҒёжүӢеҗҚгӮ’жӨңзҙўвҖҰ" autocomplete="off">
    <div class="filters" id="posF">${posChips()}</div>
    <div class="filters" id="lgF">${lgChips()}</div>
    <div class="filters" id="clubF">${clubChips()}</div>
  </div>
  <div class="list" id="plist"></div>`);
  benchAddMode=true;
  wirePicker(-1);
}
function addPlayerToBench(pid){
  if(!state.bench.includes(pid)&&!inXI(pid)) state.bench.push(pid);
  closeSheet();render();save();toast(shortName(P[pid][0])+' гӮ’гғҷгғігғҒгҒ«иҝҪеҠ гҒ—гҒҫгҒ—гҒҹ');
}
function prowHTML(i){
  const p=P[i],g=grp(p[1]),already=inXI(i);
  return `<div class="prow ${already?'inxi':''}" data-pid="${i}">
    <div class="pos ${g}">${p[1]}</div>
    <div class="meta">
      <div class="nm">${p[0].trim()} ${already?'<span class="badge">в—Ҹиө·з”Ёдёӯ</span>':''}</div>
      <div class="sub">${p[3]} В· ${p[4]} В· ${p[2]}жӯі</div>
    </div>
  </div>`;
}
function assign(slotIdx,pid){
  // еҗҢгҒҳйҒёжүӢгҒҢд»–гӮ№гғӯгғғгғҲгҒ«гҒ„гҒҹгӮүеӨ–гҒҷпјҲйҮҚиӨҮиө·з”ЁйҳІжӯўпјү
  const outgoing=state.slots[slotIdx].pid;
  state.slots.forEach(s=>{if(s.pid===pid)s.pid=null});
  state.slots[slotIdx].pid=pid;
  if(state.slots[slotIdx].sub===pid) state.slots[slotIdx].sub=null; // еҗҢжһ гҒ®гӮ№гӮҝгғЎгғіпјқз¬¬2еҖҷиЈңгҒ®йҮҚиӨҮгӮ’и§Јж¶Ҳ
  if(outgoing!=null&&outgoing!==pid) benchReturn(outgoing); // е…ғгҒ®йҒёжүӢгӮ’жҺ§гҒҲгҒёжҲ»гҒҷ
  closeSheet();render();save();
  toast(P[pid][0].trim()+' гӮ’ '+state.slots[slotIdx].role+' гҒ«й…ҚзҪ®');
}

/* ---- Slot menu (occupied) ---- */
function openSlotMenu(i){
  const s=state.slots[i];
  const p=P[s.pid];
  const hasBench=state.loadedClub&&state.bench.length>0;
  const isCapt=state.captain===s.pid;
  const subLabel=s.sub!=null&&P[s.sub] ? 'з¬¬дәҢеҖҷиЈңпјҡ'+shortName(P[s.sub][0]) : 'з¬¬дәҢеҖҷиЈңгӮ’йҒёгҒ¶';
  openSheet(`
    <h2>${shortName(p[0])} <span>${s.role}</span></h2>
    <div class="menu">
      <div class="mitem" data-act="photo"><div class="mi">рҹ“·</div>еҶҷзңҹгӮ’иҝҪеҠ  / еӨүжӣҙ</div>
      <div class="mitem" data-act="detail"><div class="mi">в„№пёҸ</div>йҒёжүӢгҒ®и©ізҙ°гӮ’иҰӢгӮӢ</div>
      <div class="mitem" data-act="change"><div class="mi">вҮ„</div>${hasBench?'йҒёжүӢгӮ’еӨүжӣҙпјҲгғҷгғігғҒе„Әе…Ҳпјү':'йҒёжүӢгӮ’еӨүжӣҙ / з§»зұҚ'}</div>
      <div class="mitem" data-act="sub"><div class="mi">в‘Ў</div>${subLabel}</div>
      <div class="mitem" data-act="captain"><div class="mi">${isCapt?'вҳ…':'рҹ‘‘'}</div>${isCapt?'гӮӯгғЈгғ—гғҶгғігӮ’и§ЈйҷӨ':'гӮӯгғЈгғ—гғҶгғігҒ«жҢҮе®ҡ'}</div>
      <div class="mitem danger" data-act="remove"><div class="mi">вң•</div>гӮ№гӮҝгғЎгғігҒӢгӮүеӨ–гҒҷ</div>
    </div>`);
  body.querySelector('.menu').onclick=e=>{
    const it=e.target.closest('[data-act]');if(!it)return;
    const a=it.dataset.act;
    if(a==='photo')pickPhoto(s.pid);
    if(a==='detail')openDetail(s.pid,i);
    if(a==='change') hasBench ? openBenchPicker(i) : openPicker(i);
    if(a==='sub') openSubPicker(i);
    if(a==='captain'){ state.captain=isCapt?null:s.pid; closeSheet();render();save();toast(isCapt?'гӮӯгғЈгғ—гғҶгғігӮ’и§ЈйҷӨ':shortName(p[0])+' гӮ’гӮӯгғЈгғ—гғҶгғігҒ«жҢҮе®ҡ'); }
    if(a==='remove'){ if(state.captain===s.pid)state.captain=null; const out=s.pid; s.pid=null; s.sub=null; benchReturn(out); closeSheet();render();save();toast('еӨ–гҒ—гҒҫгҒ—гҒҹ'); }
  };
}

/* ---- з¬¬дәҢеҖҷиЈңгғ”гғғгӮ«гғјпјҲslot.sub гҒ«еүІгӮҠеҪ“гҒҰпјү ---- */
function openSubPicker(slotIdx){
  pickFilter={pos:'ALL',lg:'ALL',club:'ALL',q:''};
  const role=state.slots[slotIdx].role;
  pickRole=role;
  const hasBench=state.loadedClub&&state.bench.length>0;
  const cur=state.slots[slotIdx].sub;
  openSheet(`
    <h2>з¬¬дәҢеҖҷиЈңгӮ’йҒёгҒ¶ <span>${role}</span></h2>
    <div class="controls">
      ${hasBench?`<div class="filters" id="benchModeF">
        <div class="fchip on" data-bm="bench">гғҷгғігғҒпјҲ${state.bench.length}дәәпјү</div>
        <div class="fchip" data-bm="transfer">вңҲ е…ЁйҒёжүӢгҒӢгӮү</div>
      </div>`:''}
      <div id="transferExtra" style="${hasBench?'display:none;':''}padding-top:6px">
        <input class="search" id="pq" placeholder="йҒёжүӢеҗҚгӮ’жӨңзҙўвҖҰ" autocomplete="off">
        <div class="filters" id="posF">${posChips()}</div>
        <div class="filters" id="lgF">${lgChips()}</div>
        <div class="filters" id="clubF">${clubChips()}</div>
      </div>
      ${cur!=null?`<div class="bench-badge">зҸҫеңЁгҒ®з¬¬дәҢеҖҷиЈңпјҡ<b>${P[cur]?shortName(P[cur][0]):'-'}</b>гҖҖ<span data-clearsub="1" style="color:var(--red);cursor:pointer;font-weight:800">и§ЈйҷӨ</span></div>`:''}
    </div>
    <div class="list" id="plist"></div>`);
  const drawSub=()=>{
    const list=document.getElementById('plist');if(!list)return;
    const usebench=!document.getElementById('transferExtra')||document.getElementById('transferExtra').style.display==='none';
    if(hasBench&&usebench){
      const pids=state.bench;
      list.innerHTML=pids.length?pids.slice().sort(suggestSort).map(pid=>prowHTML(pid)).join(''):'<div class="empty-msg">гғҷгғігғҒгҒ«йҒёжүӢгҒҢгҒ„гҒҫгҒӣгӮ“</div>';
      list.onscroll=null;
      list.onclick=e=>{const row=e.target.closest('[data-pid]');if(!row)return;assignSub(slotIdx,+row.dataset.pid);};
    }else{
      wireSubPickerFull(slotIdx);
    }
  };
  if(hasBench){
    document.getElementById('benchModeF').onclick=e=>{
      const c=e.target.closest('[data-bm]');if(!c)return;
      [...c.parentNode.children].forEach(x=>x.classList.remove('on'));c.classList.add('on');
      const te=document.getElementById('transferExtra');
      if(c.dataset.bm==='bench'){ te.style.display='none'; drawSub(); }
      else{ te.style.display='block'; pickFilter={pos:'ALL',lg:'ALL',club:'ALL',q:''};
        document.getElementById('posF').innerHTML=posChips();document.getElementById('lgF').innerHTML=lgChips();document.getElementById('clubF').innerHTML=clubChips();
        wireSubPickerFull(slotIdx); }
    };
  }
  const cb=body.querySelector('[data-clearsub]');
  if(cb)cb.onclick=()=>{state.slots[slotIdx].sub=null;closeSheet();render();save();toast('з¬¬дәҢеҖҷиЈңгӮ’и§ЈйҷӨгҒ—гҒҫгҒ—гҒҹ');};
  drawSub();
}
function wireSubPickerFull(slotIdx){
  const q=document.getElementById('pq');
  if(q) q.oninput=()=>{pickFilter.q=q.value.toLowerCase();drawSubFull(slotIdx)};
  const posF=document.getElementById('posF');
  if(posF) posF.onclick=e=>{const c=e.target.closest('[data-pos]');if(!c)return;pickFilter.pos=c.dataset.pos;[...c.parentNode.children].forEach(x=>x.classList.remove('on'));c.classList.add('on');drawSubFull(slotIdx)};
  const lgF=document.getElementById('lgF');
  if(lgF) lgF.onclick=e=>{const c=e.target.closest('[data-lg]');if(!c)return;pickFilter.lg=c.dataset.lg;pickFilter.club='ALL';[...c.parentNode.children].forEach(x=>x.classList.remove('on'));c.classList.add('on');const cf=document.getElementById('clubF');if(cf)cf.innerHTML=clubChips();const cF=document.getElementById('clubF');if(cF)cF.onclick=ev=>{const cc=ev.target.closest('[data-club]');if(!cc)return;pickFilter.club=cc.dataset.club;[...cc.parentNode.children].forEach(x=>x.classList.remove('on'));cc.classList.add('on');drawSubFull(slotIdx);};drawSubFull(slotIdx)};
  const clubF=document.getElementById('clubF');
  if(clubF) clubF.onclick=e=>{const c=e.target.closest('[data-club]');if(!c)return;pickFilter.club=c.dataset.club;[...c.parentNode.children].forEach(x=>x.classList.remove('on'));c.classList.add('on');drawSubFull(slotIdx);};
  drawSubFull(slotIdx);
}
function drawSubFull(slotIdx){
  const list=document.getElementById('plist');if(!list)return;
  pickCurIdx=P.map((p,i)=>i).filter(i=>playerMatches(P[i]));
  pickCurIdx.sort(suggestSort);
  if(!pickCurIdx.length){list.innerHTML='<div class="empty-msg">и©ІеҪ“гҒҷгӮӢйҒёжүӢгҒҢгҒ„гҒҫгҒӣгӮ“</div>';return;}
  list.innerHTML=pickCurIdx.slice(0,PAGE).map(i=>prowHTML(i)).join('');
  if(pickCurIdx.length>PAGE) list.insertAdjacentHTML('beforeend',`<div class="loadmore" id="pickMore">в–ҫ гҒ•гӮүгҒ« ${pickCurIdx.length-PAGE}дәә</div>`);
  list._loaded=Math.min(PAGE,pickCurIdx.length);
  list.onscroll=()=>{
    if(list.scrollTop+list.clientHeight>=list.scrollHeight-80){
      const start=list._loaded;if(start>=pickCurIdx.length)return;
      const more=pickCurIdx.slice(start,start+PAGE);
      const sm=document.getElementById('pickMore');
      if(sm)sm.insertAdjacentHTML('beforebegin',more.map(i=>prowHTML(i)).join(''));
      list._loaded=start+more.length;
      const ns=document.getElementById('pickMore');
      if(ns){const rem=pickCurIdx.length-list._loaded;if(rem<=0)ns.remove();else ns.textContent='в–ҫ гҒ•гӮүгҒ« '+rem+'дәә';}
    }
  };
  list.onclick=e=>{const row=e.target.closest('[data-pid]');if(!row)return;assignSub(slotIdx,+row.dataset.pid);};
}
function assignSub(slotIdx,pid){
  if(state.slots[slotIdx].pid===pid){ toast('гҒқгҒ®йҒёжүӢгҒҜгҒ“гҒ®жһ гҒ®гӮ№гӮҝгғЎгғігҒ§гҒҷ'); return; } // еҗҢжһ гҒ®гӮ№гӮҝгғЎгғігҒҜз¬¬2еҖҷиЈңгҒ«гҒ—гҒӘгҒ„
  state.slots[slotIdx].sub=pid;
  closeSheet();render();save();
  toast(shortName(P[pid][0])+' гӮ’з¬¬дәҢеҖҷиЈңгҒ«иЁӯе®ҡ');
}

/* ---- Bench-first picker (гғҒгғјгғ иӘӯиҫјеҫҢ) ---- */
function openBenchPicker(slotIdx){
  pickFilter={pos:'ALL',lg:'ALL',club:'ALL',q:''};
  const role=state.slots[slotIdx].role;
  pickRole=role;
  const blen=state.bench.length;
  openSheet(`
    <h2>йҒёжүӢгӮ’еӨүжӣҙ <span>${role}</span></h2>
    <div class="controls">
      <div class="filters" id="benchModeF">
        <div class="fchip on" data-bm="bench">гғҷгғігғҒпјҲ${blen}дәәпјү</div>
        <div class="fchip" data-bm="transfer">вңҲ з§»зұҚеёӮе ҙгҒӢгӮү</div>
      </div>
      <div id="transferExtra" style="display:none;padding-top:6px">
        <input class="search" id="pq" placeholder="йҒёжүӢеҗҚгӮ’жӨңзҙўвҖҰ" autocomplete="off">
        <div class="filters" id="posF">${posChips()}</div>
        <div class="filters" id="lgF">${lgChips()}</div>
        <div class="filters" id="clubF">${clubChips()}</div>
      </div>
    </div>
    <div class="list" id="plist"></div>`);
  drawBenchList(slotIdx);
  document.getElementById('benchModeF').onclick=e=>{
    const c=e.target.closest('[data-bm]');if(!c)return;
    [...c.parentNode.children].forEach(x=>x.classList.remove('on'));c.classList.add('on');
    const te=document.getElementById('transferExtra');
    if(c.dataset.bm==='bench'){
      te.style.display='none';
      drawBenchList(slotIdx);
    }else{
      te.style.display='block';
      pickFilter={pos:'ALL',lg:'ALL',club:'ALL',q:''};
      document.getElementById('posF').innerHTML=posChips();
      document.getElementById('lgF').innerHTML=lgChips();
      document.getElementById('clubF').innerHTML=clubChips();
      wirePicker(slotIdx);
    }
  };
}
function drawBenchList(slotIdx){
  const list=document.getElementById('plist');if(!list)return;
  const pids=state.bench;
  if(!pids.length){list.innerHTML='<div class="empty-msg">гғҷгғігғҒгҒ«йҒёжүӢгҒҢгҒ„гҒҫгҒӣгӮ“</div>';return;}
  list.innerHTML=pids.slice().sort(suggestSort).map(pid=>prowHTML(pid)).join('');
  list.onscroll=null;
  list.onclick=e=>{const row=e.target.closest('[data-pid]');if(!row)return;assign(slotIdx,+row.dataset.pid);};
}

/* ---- Player detail ---- */
function openDetail(pid,slotIdx){
  const p=P[pid];const ph=state.photos[pid];
  const inSquad=inXI(pid);
  const inBench=state.bench.includes(pid);
  let actions;
  if(slotIdx!=null){
    actions=`<button class="bigbtn" id="dPhoto">рҹ“· еҶҷзңҹгӮ’иҝҪеҠ  / еӨүжӣҙ</button>
      <button class="bigbtn ghost" id="dChange">гҒ“гҒ®йҒёжүӢгӮ’еӨүжӣҙ / з§»зұҚ</button>
      <button class="bigbtn ghost" id="dRemove">гӮ№гӮҝгғЎгғігҒӢгӮүеӨ–гҒҷ</button>`;
  }else if(inSquad){
    actions=`<button class="bigbtn" id="dPhoto">рҹ“· еҶҷзңҹгӮ’иҝҪеҠ  / еӨүжӣҙ</button>
      <button class="bigbtn ghost" disabled style="opacity:.5">гҒҷгҒ§гҒ«гӮ№гӮҝгғЎгғіиө·з”Ёдёӯ</button>`;
  }else{
    actions=`<button class="bigbtn" id="dPhoto">рҹ“· еҶҷзңҹгӮ’иҝҪеҠ  / еӨүжӣҙ</button>
      <button class="bigbtn" id="dAdd">гӮ№гӮҝгғЎгғігҒ«е…ҘгӮҢгӮӢ</button>`+
      (inBench
        ? `<button class="bigbtn ghost" id="dUnbench">гғҷгғігғҒгҒӢгӮүеӨ–гҒҷ</button>`
        : `<button class="bigbtn ghost" id="dBench">гғҷгғігғҒпјҲжҺ§гҒҲпјүгҒ«еҠ гҒҲгӮӢ</button>`);
  }
  openSheet(`
    <h2>йҒёжүӢгғ—гғӯгғ•гӮЈгғјгғ«</h2>
    <div class="detail">
      <div class="dhead">
        <div class="davatar${ph?' photo':''}"${ph?` style="background-image:url('${ph}')"`:''}>${SIL}</div>
        <div>
          <div class="dname">${p[0].trim()}</div>
          <div class="dclub">${p[3]} В· ${p[4]}</div>
        </div>
      </div>
      <div class="dgrid">
        <div class="dcell"><div class="dk">гғқгӮёгӮ·гғ§гғі</div><div class="dv">${p[1]}</div></div>
        <div class="dcell"><div class="dk">е№ҙйҪў</div><div class="dv">${p[2]}<small style="font-size:13px"> жӯі</small></div></div>
        <div class="dcell"><div class="dk">гғӘгғјгӮ°</div><div class="dv" style="font-size:17px">${L[p[5]]}</div></div>
        <div class="dcell"><div class="dk">еӣҪзұҚ</div><div class="dv" style="font-size:17px">${p[3]}</div></div>
      </div>
      ${actions}
    </div>`);
  const $=id=>document.getElementById(id);
  if($('dPhoto'))$('dPhoto').onclick=()=>pickPhoto(pid);
  if($('dChange'))$('dChange').onclick=()=>{const useBench=slotIdx!=null&&state.loadedClub&&state.bench.length>0;useBench?openBenchPicker(slotIdx):openPicker(slotIdx);};
  if($('dRemove'))$('dRemove').onclick=()=>{const out=state.slots[slotIdx].pid;state.slots[slotIdx].pid=null;benchReturn(out);closeSheet();render();save();toast('еӨ–гҒ—гҒҫгҒ—гҒҹ');};
  if($('dAdd'))$('dAdd').onclick=()=>{ state.bench=state.bench.filter(x=>x!==pid); addToXI(pid); };
  if($('dBench'))$('dBench').onclick=()=>{ if(!state.bench.includes(pid))state.bench.push(pid); closeSheet();render();save();toast('гғҷгғігғҒгҒ«еҠ гҒҲгҒҫгҒ—гҒҹ'); };
  if($('dUnbench'))$('dUnbench').onclick=()=>{ state.bench=state.bench.filter(x=>x!==pid); state.slots.forEach(s=>{if(s.sub===pid)s.sub=null;}); closeSheet();render();save();toast('гғҷгғігғҒгҒӢгӮүеӨ–гҒ—гҒҫгҒ—гҒҹ'); };
}
function addToXI(pid){
  // еҗҢгӮ°гғ«гғјгғ—гҒ®з©әгҒҚгӮ’е„Әе…ҲгҖҒгҒӘгҒ‘гӮҢгҒ°жңҖеҲқгҒ®з©әгҒҚ
  const g=grp(P[pid][1]);
  let target=state.slots.findIndex(s=>s.pid==null&&grp(s.role)===g);
  if(target<0)target=state.slots.findIndex(s=>s.pid==null);
  if(target<0){toast('гӮ№гӮҝгғЎгғігҒҢ11дәәеҹӢгҒҫгҒЈгҒҰгҒ„гҒҫгҒҷгҖӮиӘ°гҒӢгӮ’еӨ–гҒ—гҒҰгҒҸгҒ гҒ•гҒ„');return;}
  assign(target,pid);
}

/* =========================================================
   Header actions
   ========================================================= */
// з§»зұҚеёӮе ҙпјҲе…ЁйҒёжүӢгғ–гғ©гӮҰгӮәпјү
let mktFilter={pos:'ALL',lg:'ALL',club:'ALL',q:''};
document.getElementById('btnMarket').onclick=()=>{
  mktFilter={pos:'ALL',lg:'ALL',club:'ALL',q:''};
  openSheet(`
    <h2>з§»зұҚеёӮе ҙ <span>е…Ё${P.length}йҒёжүӢ</span></h2>
    <div class="controls">
      <input class="search" id="mq" placeholder="йҒёжүӢеҗҚгғ»гӮҜгғ©гғ–гҒ§жӨңзҙўвҖҰ" autocomplete="off">
      <div class="filters" id="mposF">${posChips(mktFilter)}</div>
      <div class="filters" id="mlgF">${lgChips(mktFilter)}</div>
      <div class="filters" id="mclubF">${clubChips(mktFilter)}</div>
    </div>
    <div class="list" id="mlist"></div>`);
  document.getElementById('mq').oninput=e=>{mktFilter.q=e.target.value.toLowerCase();drawMkt()};
  document.getElementById('mposF').onclick=e=>{const c=e.target.closest('[data-pos]');if(!c)return;mktFilter.pos=c.dataset.pos;[...c.parentNode.children].forEach(x=>x.classList.remove('on'));c.classList.add('on');drawMkt()};
  document.getElementById('mlgF').onclick=e=>{const c=e.target.closest('[data-lg]');if(!c)return;mktFilter.lg=c.dataset.lg;mktFilter.club='ALL';[...c.parentNode.children].forEach(x=>x.classList.remove('on'));c.classList.add('on');document.getElementById('mclubF').innerHTML=clubChips(mktFilter);wireMktClub();drawMkt()};
  wireMktClub();
  drawMkt();
};
function wireMktClub(){
  const mclubF=document.getElementById('mclubF');if(!mclubF)return;
  mclubF.onclick=e=>{const c=e.target.closest('[data-club]');if(!c)return;mktFilter.club=c.dataset.club;[...c.parentNode.children].forEach(x=>x.classList.remove('on'));c.classList.add('on');drawMkt();};
}
function drawMkt(){
  const list=document.getElementById('mlist');if(!list)return;
  const f=mktFilter;
  mktCurIdx=P.map((p,i)=>i).filter(i=>{
    const p=P[i];
    if(f.lg!=='ALL'&&p[5]!==f.lg)return false;
    if(f.pos!=='ALL'&&grp(p[1]).toUpperCase()!==f.pos)return false;
    if(f.club!=='ALL'&&p[4].trim()!==f.club)return false;
    if(f.q&&!(p[0].toLowerCase().includes(f.q)||p[4].toLowerCase().includes(f.q)))return false;
    return true;
  });
  mktCurIdx.sort((a,b)=>P[b][2]-P[a][2]);
  if(!mktCurIdx.length){list.innerHTML='<div class="empty-msg">и©ІеҪ“гҒҷгӮӢйҒёжүӢгҒҢгҒ„гҒҫгҒӣгӮ“</div>';return;}
  list.innerHTML=mktCurIdx.slice(0,PAGE).map(i=>prowHTML(i)).join('');
  if(mktCurIdx.length>PAGE) list.insertAdjacentHTML('beforeend',`<div class="loadmore" id="mktMore">в–ҫ гҒ•гӮүгҒ« ${mktCurIdx.length-PAGE}дәә</div>`);
  list._loaded=Math.min(PAGE,mktCurIdx.length);
  list.onscroll=()=>{
    if(list.scrollTop+list.clientHeight>=list.scrollHeight-80){
      const start=list._loaded;if(start>=mktCurIdx.length)return;
      const more=mktCurIdx.slice(start,start+PAGE);
      const s=document.getElementById('mktMore');
      if(s)s.insertAdjacentHTML('beforebegin',more.map(i=>prowHTML(i)).join(''));
      list._loaded=start+more.length;
      const ns=document.getElementById('mktMore');
      if(ns){const rem=mktCurIdx.length-list._loaded;if(rem<=0)ns.remove();else ns.textContent='в–ҫ гҒ•гӮүгҒ« '+rem+'дәә';}
    }
  };
  list.onclick=e=>{const row=e.target.closest('[data-pid]');if(!row)return;openDetail(+row.dataset.pid,null);};
}

// гӮҜгғ©гғ–гҒ®гӮ№гӮҝгғЎгғігӮ’дёҖжӢ¬иӘӯиҫј
document.getElementById('btnLoad').onclick=()=>{
  const allClubs=[...new Set(P.map(p=>p[4].trim()))].sort();
  const lgOpts=[["ALL","е…ЁгғӘгғјгӮ°"],["PL","гғ—гғ¬гғҹгӮў"],["LL","гғ©гғ»гғӘгғјгӮ¬"],["SA","гӮ»гғӘгӮЁA"],["BL","гғ–гғігғҮгӮ№"],["L1","гғӘгғјгӮ°гғ»гӮўгғі"]];
  let cLg='ALL', cQ='';
  openSheet(`
    <h2>гӮҜгғ©гғ–гӮ’иӘӯгҒҝиҫјгӮҖ <span>11дәәгӮ’иҮӘеӢ•й…ҚзҪ®</span></h2>
    <div class="controls">
      <div class="origbtn" id="cOrig">вңҺ гӮӘгғӘгӮёгғҠгғ«гғҒгғјгғ гӮ’дҪңжҲҗпјҲгӮјгғӯгҒӢгӮүзө„гӮҖпјү</div>
      <div class="filters" id="cLgF">
        ${lgOpts.map(o=>`<div class="fchip ${o[0]==='ALL'?'on':''}" data-clg="${o[0]}">${o[1]}</div>`).join('')}
      </div>
      <input class="search" id="cq" placeholder="гӮҜгғ©гғ–еҗҚгӮ’жӨңзҙўвҖҰ" autocomplete="off" style="margin-top:6px">
    </div>
    <div class="list" id="clist"></div>`);
  document.getElementById('cOrig').onclick=startOriginal;
  function renderClist(){
    const clubs=allClubs.filter(c=>{
      if(cLg!=='ALL'){const p=P.find(p=>p[4].trim()===c);if(!p||p[5]!==cLg)return false;}
      if(cQ&&!c.toLowerCase().includes(cQ))return false;
      return true;
    });
    document.getElementById('clist').innerHTML=clubs.length
      ?clubs.map(c=>clubRow(c)).join('')
      :'<div class="empty-msg">и©ІеҪ“гҒҷгӮӢгӮҜгғ©гғ–гҒҢгҒӮгӮҠгҒҫгҒӣгӮ“</div>';
  }
  document.getElementById('cLgF').onclick=e=>{
    const c=e.target.closest('[data-clg]');if(!c)return;
    cLg=c.dataset.clg;[...c.parentNode.children].forEach(x=>x.classList.remove('on'));c.classList.add('on');
    renderClist();
  };
  document.getElementById('cq').oninput=e=>{cQ=e.target.value.toLowerCase();renderClist();};
  document.getElementById('clist').onclick=e=>{const row=e.target.closest('[data-club]');if(!row)return;loadClub(row.dataset.club);};
  renderClist();
};
/* гӮҜгғ©гғ–еҗҚгҒӢгӮүжұәе®ҡзҡ„гҒ«иүІгӮ’з”ҹжҲҗгҒ—гҒҰгӮЁгғігғ–гғ¬гғ йўЁгғҗгғғгӮёгӮ’дҪңгӮӢ */
function clubColors(c){
  let h=0;for(let k=0;k<c.length;k++)h=(h*31+c.charCodeAt(k))>>>0;
  const hue=h%360, hue2=(hue+40)%360;
  return [`hsl(${hue},58%,42%)`,`hsl(${hue2},60%,30%)`];
}
function clubRow(c){
  const players=P.filter(p=>p[4].trim()===c);
  const lg=L[players[0][5]];
  const [a,b]=clubColors(c);
  const init=c.split(' ').map(w=>w[0]).join('').slice(0,3).toUpperCase();
  return `<div class="prow" data-club="${c}">
    <div class="emblem" style="width:40px;height:40px;font-size:14px;flex:0 0 auto;background:linear-gradient(150deg,${a},${b})">${init}</div>
    <div class="meta"><div class="nm">${c}</div><div class="sub">${lg} В· ${players.length}еҗҚеҸҺйҢІ</div></div>
  </div>`;
}
// гӮӘгғӘгӮёгғҠгғ«гғҒгғјгғ дҪңжҲҗпјҡгҒҫгҒҡгғ—гғӯгғ•гӮЈгғјгғ«пјҲгғҒгғјгғ еҗҚгҒӘгҒ©пјүгӮ’е…ҘеҠӣ
function startOriginal(){
  const info=state.teamInfo||{};
  openSheet(`
    <h2>гӮӘгғӘгӮёгғҠгғ«гғҒгғјгғ дҪңжҲҗ <span>гғ—гғӯгғ•гӮЈгғјгғ«</span></h2>
    <div class="detail">
      <div class="formfield">
        <label>гғҒгғјгғ еҗҚ <i>еҝ…й Ҳ</i></label>
        <input class="search" id="otName" maxlength="24" placeholder="дҫӢпјҡгғ¬гғғгғүгғүгғ©гӮҙгғігӮә" value="${(state.teamName&&!state.loadedClub)?escAttr(state.teamName):''}" autocomplete="off">
      </div>
      <div class="formfield">
        <label>гӮ№гғӯгғјгӮ¬гғі / ж„ӣз§° <i>д»»ж„Ҹ</i></label>
        <input class="search" id="otTag" maxlength="30" placeholder="дҫӢпјҡзҺӢиҖ…гҒёгҒ®жҢ‘жҲҰ" value="${info.slogan?escAttr(info.slogan):''}" autocomplete="off">
      </div>
      <div class="formfield">
        <label>зӣЈзқЈеҗҚ <i>д»»ж„Ҹ</i></label>
        <input class="search" id="otMgr" maxlength="24" placeholder="дҫӢпјҡеұұз”° еӨӘйғҺ" value="${info.manager?escAttr(info.manager):''}" autocomplete="off">
      </div>
      <div class="formfield">
        <label>жң¬жӢ ең° <i>д»»ж„Ҹ</i></label>
        <input class="search" id="otHome" maxlength="24" placeholder="дҫӢпјҡжқұдә¬" value="${info.home?escAttr(info.home):''}" autocomplete="off">
      </div>
      <div class="formfield">
        <label>гғҒгғјгғ гӮ«гғ©гғј</label>
        <div class="colorrow" id="otColors">
          ${['#caff3a','#ff5b6e','#4fc3f7','#ffd166','#a78bfa','#ff8a65','#4ade80','#f472b6'].map((c,i)=>`<span class="cdot2${(info.color||'#caff3a')===c?' on':''}" data-color="${c}" style="background:${c}"></span>`).join('')}
        </div>
      </div>
      <button class="bigbtn" id="otStart">гҒ“гҒ®еҶ…е®№гҒ§гғҒгғјгғ гӮ’дҪңжҲҗ вҶ’</button>
      <button class="bigbtn ghost" id="otBlank">еҗҚеүҚгҒ гҒ‘гҒ§д»ҠгҒҷгҒҗдҪңжҲҗ</button>
    </div>`);
  let chosen=info.color||'#caff3a';
  document.getElementById('otColors').onclick=e=>{
    const c=e.target.closest('[data-color]');if(!c)return;
    chosen=c.dataset.color;[...c.parentNode.children].forEach(x=>x.classList.remove('on'));c.classList.add('on');
  };
  const build=()=>{
    const name=(document.getElementById('otName').value||'').trim();
    if(!name){ toast('гғҒгғјгғ еҗҚгӮ’е…ҘеҠӣгҒ—гҒҰгҒҸгҒ гҒ•гҒ„'); document.getElementById('otName').focus(); return; }
    state.slots.forEach(s=>{s.pid=null;s.sub=null;});
    state.bench=[];
    state.loadedClub=null;
    state.captain=null;
    state.teamName=name;
    state.teamInfo={
      slogan:(document.getElementById('otTag').value||'').trim(),
      manager:(document.getElementById('otMgr').value||'').trim(),
      home:(document.getElementById('otHome').value||'').trim(),
      color:chosen
    };
    closeSheet();render();save();
    toast(name+' гӮ’дҪңжҲҗпјҒз©әгҒҚгҒ®в—ҜгӮ’гӮҝгғғгғ—гҒ—гҒҰйҒёжүӢгӮ’й…ҚзҪ®');
  };
  document.getElementById('otStart').onclick=build;
  document.getElementById('otBlank').onclick=build;
}
function escAttr(s){return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function loadClub(club){
  const ids=P.map((p,i)=>i).filter(i=>P[i][4].trim()===club);
  // еҗ„гӮ№гғӯгғғгғҲгӮ’гҖҒгҒқгҒ®еҪ№еүІгҒ®гӮөгӮёгӮ§гӮ№гғҲй ҶгҒ§жңҖйҒ©гҒӘйҒёжүӢгҒӢгӮүеҹӢгӮҒгӮӢпјҲйҒ©жҖ§гғқгӮёгӮ·гғ§гғіе„Әе…Ҳпјү
  const used=new Set();
  const savedRole=pickRole;
  state.slots.forEach(s=>{
    pickRole=s.role;
    const pid=ids.filter(id=>!used.has(id)).sort(suggestSort)[0];
    if(pid!=null){used.add(pid);s.pid=pid;} else s.pid=null;
  });
  pickRole=savedRole;
  // иө·з”ЁгҒ—гҒӘгҒӢгҒЈгҒҹж®ӢгӮҠгҒ®йҒёжүӢгҒҜгғҷгғігғҒгҒё
  state.bench=ids.filter(id=>!used.has(id));
  state.loadedClub=club;
  state.teamName=club;
  state.teamInfo=null;
  state.captain=null;
  autoAssignSubs(); // з¬¬дәҢеҖҷиЈңгӮ’еҲқжңҹеүІеҪ“пјҲд»ҘеҫҢгҒҜжүӢеӢ•гғ»иҮӘеӢ•гҒ§гҒҜеӨүгӮҸгӮүгҒӘгҒ„пјү
  closeSheet();render();save();toast(club+' гҒ®гӮ№гӮҝгғЎгғігғ»жҺ§гҒҲгғ»з¬¬дәҢеҖҷиЈңгӮ’й…ҚзҪ®гҒ—гҒҫгҒ—гҒҹ');
}

/* ---- гӮ№гӮ«гғғгғүеҲҶжһҗпјҲгӮ№гӮҝгғғгғ„гғҗгғјгӮ’гӮҝгғғгғ—пјү ---- */
document.getElementById('statbar').onclick=openSquadAnalysis;
function openSquadAnalysis(){
  const xi=state.slots.filter(s=>s.pid!=null).map(s=>P[s.pid]);
  if(!xi.length){ toast('гҒҫгҒҡйҒёжүӢгӮ’й…ҚзҪ®гҒ—гҒҰгҒҸгҒ гҒ•гҒ„'); return; }
  const bench=state.bench.map(pid=>P[pid]);
  const all=xi.concat(bench);
  const sum=a=>a.reduce((x,y)=>x+y,0);
  const ages=xi.map(p=>p[2]);
  const avg=(sum(ages)/ages.length).toFixed(1);
  const cnt={GK:0,DF:0,MF:0,FW:0};
  xi.forEach(p=>{const g=grp(p[1]).toUpperCase();cnt[g]=(cnt[g]||0)+1;});
  const youngest=[...xi].sort((a,b)=>a[2]-b[2])[0];
  const oldest=[...xi].sort((a,b)=>b[2]-a[2])[0];
  // еӣҪзұҚйӣҶиЁҲпјҲгғ•гғ©гӮ°пјӢз•ҘеҸ·гҖӮе…ЁгӮ«еӣҪгӮ’иЎЁзӨәпјү
  const nat={};
  xi.forEach(p=>{const key=p[3].trim();nat[key]=(nat[key]||0)+1;});
  const natTop=Object.entries(nat).sort((a,b)=>b[1]-a[1]).map(e=>e[0]+(e[1]>1?' Г—'+e[1]:'')).join('гҖҖ');
  const natCount=Object.keys(nat).length;
  const captP=state.captain!=null&&P[state.captain]?shortName(P[state.captain][0]):'жңӘиЁӯе®ҡ';
  openSheet(`
    <h2>гӮ№гӮ«гғғгғүеҲҶжһҗ <span>${teamDisplayName()||'гӮӘгғӘгӮёгғҠгғ«'}</span></h2>
    <div class="detail">
      <div class="dgrid">
        <div class="dcell"><div class="dk">е№іеқҮе№ҙйҪў</div><div class="dv lime">${avg}<small style="font-size:13px"> жӯі</small></div></div>
        <div class="dcell"><div class="dk">иө·з”Ёдәәж•°</div><div class="dv">${xi.length}<small style="font-size:13px">/11</small></div></div>
        <div class="dcell"><div class="dk">жҺ§гҒҲйҒёжүӢ</div><div class="dv">${bench.length}<small style="font-size:13px"> дәә</small></div></div>
        <div class="dcell full"><div class="dk">гғқгӮёгӮ·гғ§гғіж§ӢжҲҗ (GKгғ»DFгғ»MFгғ»FW)</div>
          <div class="dv">${cnt.GK} гғ» ${cnt.DF} гғ» ${cnt.MF} гғ» ${cnt.FW}</div>
          ${posBar(cnt,xi.length)}
        </div>
        <div class="dcell"><div class="dk">гӮӯгғЈгғ—гғҶгғі</div><div class="dv" style="font-size:18px">${captP}</div></div>
        <div class="dcell"><div class="dk">жңҖе№ҙе°‘</div><div class="dv" style="font-size:18px">${shortName(youngest[0])}</div><div class="dk" style="margin-top:3px;text-transform:none;letter-spacing:0">${youngest[2]}жӯі</div></div>
        <div class="dcell"><div class="dk">жңҖе№ҙй•·</div><div class="dv" style="font-size:18px">${shortName(oldest[0])}</div><div class="dk" style="margin-top:3px;text-transform:none;letter-spacing:0">${oldest[2]}жӯі</div></div>
        <div class="dcell full"><div class="dk">еӣҪзұҚ (${natCount}гӮ«еӣҪ)</div><div class="dv" style="font-size:16px">${natTop}</div></div>
      </div>
      <button class="bigbtn ghost" id="saClose">й–үгҒҳгӮӢ</button>
    </div>`);
  const c=document.getElementById('saClose');if(c)c.onclick=closeSheet;
}
function posBar(cnt,total){
  const cols={GK:'#ffd166',DF:'#4fc3f7',MF:'#caff3a',FW:'#ff8a65'};
  const seg=['GK','DF','MF','FW'].filter(k=>cnt[k]>0).map(k=>
    `<div style="flex:${cnt[k]};background:${cols[k]}"></div>`).join('');
  return `<div style="display:flex;height:8px;border-radius:5px;overflow:hidden;margin-top:8px;gap:2px">${seg}</div>`;
}

/* =========================================================
   SNSе…ұжңүпјҡгӮ№гӮҝгғЎгғіз”»еғҸгӮ’з”ҹжҲҗгҒ—гҒҰе…ұжңүпјҲз”»еғҸпјӢгӮўгғ—гғӘгғӘгғігӮҜпјү
   ========================================================= */
const APP_URL='https://starting-xi.app';
function roleCol(role){const g=grp(role);return {gk:'#ffd166',df:'#4fc3f7',mf:'#caff3a',fw:'#ff8a65'}[g]||'#caff3a';}
function roundRect(x,X,Y,W,H,r){x.beginPath();x.moveTo(X+r,Y);x.arcTo(X+W,Y,X+W,Y+H,r);x.arcTo(X+W,Y+H,X,Y+H,r);x.arcTo(X,Y+H,X,Y,r);x.arcTo(X,Y,X+W,Y,r);x.closePath();}

// з«Ҝжң«еҶ…гҒ®йҒёжүӢеҶҷзңҹгӮ’дәӢеүҚгғӯгғјгғүпјҲе…ұжңүз”»еғҸгҒ«еҸҚжҳ гҒҷгӮӢгҒҹгӮҒпјү
function preloadPhotos(){
  const targets=state.slots.filter(s=>s.pid!=null&&state.photos[s.pid]);
  return Promise.all(targets.map(s=>new Promise(res=>{
    const im=new Image();
    im.onload=()=>res([s.pid,im]); im.onerror=()=>res(null);
    im.src=state.photos[s.pid];
  }))).then(arr=>{ const m={}; arr.forEach(e=>{ if(e)m[e[0]]=e[1]; }); return m; });
}
// й ӯгҖңиӮ©гҒ®гӮ·гғ«гӮЁгғғгғҲпјҲгӮӨгғӢгӮ·гғЈгғ«гҒҜе…ҘгӮҢгҒӘгҒ„пјү
function drawSilhouette(x,fx,fy,R){
  x.save();
  x.beginPath();x.arc(fx,fy,R-4,0,7);x.clip();
  x.fillStyle='rgba(234,255,240,.82)';
  // й ӯ
  x.beginPath();x.arc(fx,fy-9,12,0,7);x.fill();
  // иӮ©
  x.beginPath();x.arc(fx,fy+30,23,Math.PI,2*Math.PI);x.fill();
  x.restore();
}
async function buildShareCanvas(){
  const photoImgs=await preloadPhotos();
  const W=1080,H=1440,cv=document.createElement('canvas');cv.width=W;cv.height=H;
  const x=cv.getContext('2d');
  const accent=(state.teamInfo&&state.teamInfo.color)||'#caff3a';
  // иғҢжҷҜ
  const bg=x.createLinearGradient(0,0,0,H);bg.addColorStop(0,'#16221c');bg.addColorStop(.45,'#0a0e0c');bg.addColorStop(1,'#0a0e0c');
  x.fillStyle=bg;x.fillRect(0,0,W,H);
  // гғҳгғғгғҖгғјпјҡгӮўгғ—гғӘеҗҚпјҲеёёгҒ«иЎЁзӨәпјү
  x.textBaseline='alphabetic';x.textAlign='left';
  x.font='800 58px Manrope,sans-serif';x.fillStyle='#eafff0';x.fillText('STARTING',56,104);
  const w1=x.measureText('STARTING ').width;
  x.fillStyle=accent;x.fillText(' XI',56+w1,104);
  // гғ•гӮ©гғјгғЎгғјгӮ·гғ§гғіеҸідёҠ
  x.textAlign='right';x.font='800 46px "Bebas Neue",Manrope,sans-serif';x.fillStyle='#7d9389';
  x.fillText(state.formation,W-56,100);x.textAlign='left';
  // гғҒгғјгғ еҗҚпјҲгғ”гғ«пјү
  const tn=teamDisplayName();let headBottom=150;
  if(tn){
    x.font='800 34px Manrope,sans-serif';const pw=Math.min(x.measureText(tn).width,W-180);
    x.fillStyle=accent;roundRect(x,56,128,pw+52,60,30);x.fill();
    x.fillStyle='#0a0e0c';x.fillText(tn,84,170);headBottom=210;
    if(state.teamInfo&&state.teamInfo.slogan){x.font='600 26px Manrope,sans-serif';x.fillStyle='#7d9389';x.fillText(state.teamInfo.slogan,58,244);headBottom=260;}
  }
  // гғ”гғғгғҒ
  const px=46,py=Math.max(270,headBottom+30),pw=W-92,ph=920;
  // иҠқгҒ®гӮ№гғҲгғ©гӮӨгғ—
  const stripes=11;for(let i=0;i<stripes;i++){x.fillStyle=(i%2===0)?'#15493a':'#12402f';x.fillRect(px,py+ph/stripes*i,pw,ph/stripes+1);}
  roundRect(x,px,py,pw,ph,24);x.save();x.clip();
  // гғһгғјгӮӯгғігӮ°
  x.strokeStyle='rgba(255,255,255,.16)';x.lineWidth=3;
  x.strokeRect(px+pw*0.24,py,pw*0.52,ph*0.14);
  x.strokeRect(px+pw*0.24,py+ph*0.86,pw*0.52,ph*0.14);
  x.beginPath();x.moveTo(px+pw*0.05,py+ph/2);x.lineTo(px+pw*0.95,py+ph/2);x.stroke();
  x.beginPath();x.arc(px+pw/2,py+ph/2,pw*0.13,0,7);x.stroke();
  x.restore();
  roundRect(x,px,py,pw,ph,24);x.lineWidth=4;x.strokeStyle='rgba(255,255,255,.12)';x.stroke();
  // гғҲгғјгӮҜгғі
  state.slots.forEach(s=>{
    if(s.pid==null)return;const p=P[s.pid];
    const fx=px+(s.x/100)*pw, fy=py+((100-s.y)/100)*ph, R=42;
    x.beginPath();x.arc(fx,fy,R,0,7);x.fillStyle='#10160f';x.fill();
    x.textAlign='center';
    const im=photoImgs[s.pid];
    if(im){
      // гғҰгғјгӮ¶гғјгҒҢиҝҪеҠ гҒ—гҒҹеҶҷзңҹгӮ’еҶҶеҪўгҒ«еҸҚжҳ 
      x.save();x.beginPath();x.arc(fx,fy,R-4,0,7);x.clip();
      const side=Math.min(im.width,im.height);
      const sx=(im.width-side)/2, sy=(im.height-side)/2;
      x.drawImage(im,sx,sy,side,side, fx-(R-4),fy-(R-4),(R-4)*2,(R-4)*2);
      x.restore();
    }else{
      // еҶҷзңҹгҒӘгҒ—гҒҜй ӯгҒ®еҪўгҒ®гӮ·гғ«гӮЁгғғгғҲпјҲгӮӨгғӢгӮ·гғЈгғ«гҒҜе…ҘгӮҢгҒӘгҒ„пјү
      drawSilhouette(x,fx,fy,R);
    }
    x.lineWidth=6;x.strokeStyle=roleCol(s.role);x.beginPath();x.arc(fx,fy,R,0,7);x.stroke();
    // гӮӯгғЈгғ—гғҶгғі
    if(state.captain===s.pid){x.beginPath();x.arc(fx-R+8,fy-R+8,16,0,7);x.fillStyle='#ffd166';x.fill();x.fillStyle='#0a0e0c';x.font='800 20px Manrope,sans-serif';x.fillText('C',fx-R+8,fy-R+15);}
    // еҗҚеүҚ
    x.fillStyle='#eafff0';x.font='800 26px Manrope,sans-serif';
    x.fillText(shortName(p[0]),fx,fy+R+46);
    // еҪ№иҒ·
    x.fillStyle=roleCol(s.role);x.font='700 19px Manrope,sans-serif';
    x.fillText(s.role,fx,fy+R+70);
    // з¬¬дәҢеҖҷиЈң
    if(s.sub!=null&&P[s.sub]){x.fillStyle='#ffc46b';x.font='700 18px Manrope,sans-serif';x.fillText('в–ё '+shortName(P[s.sub][0]),fx,fy+R+92);}
    x.textAlign='left';
  });
  // гғ•гғғгӮҝгғј
  const fy=py+ph+58;
  const xi=state.slots.filter(s=>s.pid!=null).map(s=>P[s.pid]);
  const avgAge=xi.length?(xi.reduce((a,p)=>a+p[2],0)/xi.length).toFixed(1):'вҖ“';
  x.fillStyle='#7d9389';x.font='700 26px Manrope,sans-serif';x.textAlign='left';
  x.fillText('AVG AGE',56,fy);
  x.fillStyle=accent;x.font='800 40px "Bebas Neue",Manrope,sans-serif';
  x.fillText(avgAge,56,fy+44);
  x.textAlign='right';x.fillStyle='#5a6b62';x.font='700 24px Manrope,sans-serif';
  x.fillText('вҡҪ made with STARTING XI',W-56,fy);
  x.fillStyle=accent;x.font='700 24px Manrope,sans-serif';
  x.fillText(APP_URL.replace('https://',''),W-56,fy+38);
  x.textAlign='left';
  return cv;
}

async function shareLineup(){
  const filled=state.slots.filter(s=>s.pid!=null).length;
  if(!filled){ toast('гҒҫгҒҡйҒёжүӢгӮ’й…ҚзҪ®гҒ—гҒҰгҒҸгҒ гҒ•гҒ„'); return; }
  toast('з”»еғҸгӮ’з”ҹжҲҗдёӯвҖҰ');
  const tn=teamDisplayName();
  const shareText=(tn?tn+' ':'')+'гҒ®жңҖеј·гӮ№гӮҝгғЎгғівҡҪ #StartingXI гҒ§дҪңжҲҗпјҒ';
  let canvas;
  try{ canvas=await buildShareCanvas(); }catch(e){ toast('з”»еғҸгҒ®з”ҹжҲҗгҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹ'); return; }
  canvas.toBlob(blob=>{
    if(!blob){ toast('з”»еғҸгҒ®з”ҹжҲҗгҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹ'); return; }
    const file=new File([blob],'starting-xi.png',{type:'image/png'});
    if(navigator.canShare&&navigator.canShare({files:[file]})){
      navigator.share({files:[file],text:shareText,url:APP_URL}).catch(()=>{});
    }else{
      openShareFallback(URL.createObjectURL(blob),shareText);
    }
  },'image/png');
}
// е…ұжңүйқһеҜҫеҝңжҷӮпјҡз”»еғҸгғ—гғ¬гғ“гғҘгғјпјӢгӮўгғ—гғӘгғӘгғігӮҜпјҲйқ’гғ»иҰӢеҲҮгӮҢиЎЁзӨәпјүпјӢдҝқеӯҳ/гӮігғ”гғј
function openShareFallback(imgUrl,shareText){
  openSheet(`
    <h2>SNSгҒ«е…ұжңү <span>гғ—гғ¬гғ“гғҘгғј</span></h2>
    <div class="detail">
      <div class="shareprev"><img src="${imgUrl}" alt="lineup"></div>
      <div class="sharecap">${escAttr(shareText)}</div>
      <div class="sharelink"><span class="sl">${APP_URL}/s/${Math.random().toString(36).slice(2,9)}</span></div>
      <button class="bigbtn" id="shDl">з”»еғҸгӮ’дҝқеӯҳ</button>
      <button class="bigbtn ghost" id="shCopy">гғӘгғігӮҜгӮ’гӮігғ”гғј</button>
    </div>`);
  document.getElementById('shDl').onclick=()=>{const a=document.createElement('a');a.href=imgUrl;a.download='starting-xi.png';a.click();toast('з”»еғҸгӮ’дҝқеӯҳгҒ—гҒҫгҒ—гҒҹ');};
  document.getElementById('shCopy').onclick=async()=>{try{await navigator.clipboard.writeText(shareText+' '+APP_URL);toast('гғӘгғігӮҜгӮ’гӮігғ”гғјгҒ—гҒҫгҒ—гҒҹ');}catch(e){toast('гӮігғ”гғјгҒ§гҒҚгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹ');}};
}
document.getElementById('btnShare').onclick=shareLineup;

// ж•ҙеҲ—гғӘгӮ»гғғгғҲпјҲгғ•гӮ©гғјгғЎгғјгӮ·гғ§гғіж—ўе®ҡдҪҚзҪ®гҒёпјү
document.getElementById('btnReset').onclick=()=>{
  const f=FORM[state.formation];
  state.slots.forEach((s,i)=>{s.x=f[i][1];s.y=f[i][2];});
  render();save();toast('ж—ўе®ҡгҒ®й…ҚзҪ®гҒ«жҲ»гҒ—гҒҫгҒ—гҒҹ');
};

/* =========================================================
   Toast
   ========================================================= */
let tT;const toastEl=document.getElementById('toast');
function toast(m){toastEl.textContent=m;toastEl.classList.add('on');clearTimeout(tT);tT=setTimeout(()=>toastEl.classList.remove('on'),1900);}

/* =========================================================
   Init
   ========================================================= */
(async function init(){
  const saved=await load();
  const ph=await loadPhotos();
  if(ph&&typeof ph==='object')state.photos=ph;
  if(saved&&saved.slots&&saved.slots.length===11){
    state.formation=saved.formation||"4-3-3";
    state.slots=saved.slots;
    state.bench=Array.isArray(saved.bench)?saved.bench:[];
    state.loadedClub=saved.loadedClub||null;
    state.captain=(saved.captain!=null)?saved.captain:null;
    state.teamName=saved.teamName||null;
    state.teamInfo=saved.teamInfo||null;
    [...fbar.children].forEach(c=>c.classList.toggle('on',c.textContent===state.formation));
  }else{
    buildSlots("4-3-3",false);
  }
  render();
})();
</script>
