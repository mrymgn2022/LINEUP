<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
<title>STARTING XI вҖ” жҲҰиЎ“гғңгғјгғү</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;600;700;800&display=swap');

:root{
  --bg:#0a0e0c;
  --panel:#111714;
  --panel2:#171f1b;
  --line:#243029;
  --grass-a:#15493a;
  --grass-b:#12402f;
  --lime:#caff3a;
  --lime-dim:#9ec92a;
  --ink:#eafff0;
  --mut:#7d9389;
  --red:#ff5b6e;
  --gold:#ffd166;
  --shadow:0 10px 30px rgba(0,0,0,.45);
}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{margin:0;padding:0;height:100%}
body{
  background:
    radial-gradient(120% 80% at 50% -10%, #16221c 0%, var(--bg) 55%) fixed;
  color:var(--ink);
  font-family:'Manrope',system-ui,sans-serif;
  overflow:hidden;
  user-select:none;-webkit-user-select:none;
}
.app{display:flex;flex-direction:column;height:100dvh;max-width:560px;margin:0 auto;position:relative;overflow:hidden}
.scroll{flex:1;min-height:0;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;overscroll-behavior:contain;touch-action:pan-y}

/* ---------- Header ---------- */
header{
  padding:calc(env(safe-area-inset-top) + 10px) 14px 8px;
  display:flex;align-items:center;gap:10px;flex-shrink:0;
}
.brand{min-width:0;flex-shrink:1}
.logo{font-family:'Bebas Neue';font-size:25px;letter-spacing:1.5px;line-height:.9;color:var(--ink);white-space:nowrap}
.logo b{color:var(--lime)}
.tag{font-size:9px;letter-spacing:3px;color:var(--mut);text-transform:uppercase;margin-top:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:170px}
.tag.team{
  letter-spacing:.3px;text-transform:none;font-size:11px;font-weight:800;color:#0a0e0c;
  background:var(--lime);display:inline-flex;align-items:center;gap:4px;
  padding:2px 9px;border-radius:999px;
}
.tag.team::before{content:'в—Ҹ';font-size:7px}
.hbtn{margin-left:auto;display:flex;gap:6px;flex-shrink:0}
.icon{
  width:36px;height:36px;border-radius:11px;border:1px solid var(--line);
  background:var(--panel);color:var(--ink);font-size:15px;display:grid;place-items:center;
  cursor:pointer;transition:.15s;
}
.icon:active{transform:scale(.92);background:var(--panel2)}
.icon svg{width:19px;height:19px;display:block}

/* ---------- Formation bar ---------- */
.fbar{display:flex;gap:7px;overflow-x:auto;padding:4px 14px 10px;flex-shrink:0;scrollbar-width:none}
.fbar::-webkit-scrollbar{display:none}
.chip{
  flex:0 0 auto;padding:8px 13px;border-radius:999px;border:1px solid var(--line);
  background:var(--panel);font-family:'Bebas Neue';font-size:16px;letter-spacing:1.5px;
  color:var(--mut);cursor:pointer;transition:.15s;white-space:nowrap;
}
.chip.on{background:var(--lime);color:#0a0e0c;border-color:var(--lime);box-shadow:0 4px 14px rgba(202,255,58,.25)}
.chip:active{transform:scale(.95)}

/* ---------- Pitch ---------- */
.pitchwrap{padding:8px 12px 8px;position:relative}
.pitch{
  position:relative;width:100%;height:min(70vh,580px);border-radius:18px;overflow:hidden;
  background:
    repeating-linear-gradient(0deg, var(--grass-a) 0 9.09%, var(--grass-b) 9.09% 18.18%);
  box-shadow:inset 0 0 0 2px rgba(255,255,255,.10), var(--shadow);
}
.pitch .markings{position:absolute;inset:0;pointer-events:none}
.mk{position:absolute;border:2px solid rgba(255,255,255,.16)}
.mk.center-line{left:5%;right:5%;top:50%;height:0;border-width:2px 0 0 0}
.mk.center-circle{left:50%;top:50%;width:34%;padding-bottom:34%;height:0;border-radius:50%;transform:translate(-50%,-50%)}
.mk.spot{width:5px;height:5px;background:rgba(255,255,255,.4);border:0;border-radius:50%;left:50%;top:50%;transform:translate(-50%,-50%)}
.mk.box-top{left:24%;right:24%;top:0;height:14%;border-top:0}
.mk.box-top-s{left:36%;right:36%;top:0;height:6%;border-top:0}
.mk.box-bot{left:24%;right:24%;bottom:0;height:14%;border-bottom:0}
.mk.box-bot-s{left:36%;right:36%;bottom:0;height:6%;border-bottom:0}

/* ---------- Player token ---------- */
.tok{
  position:absolute;width:64px;transform:translate(-50%,-50%);
  display:flex;flex-direction:column;align-items:center;cursor:grab;touch-action:none;z-index:2;
}
.tok.drag{z-index:30;cursor:grabbing}
.disc{
  width:44px;height:44px;border-radius:50%;display:grid;place-items:center;position:relative;
  background:linear-gradient(160deg,#1d2722,#10160f);
  border:2px solid var(--lime);box-shadow:0 5px 14px rgba(0,0,0,.5);
  font-weight:800;font-size:13px;color:var(--ink);
}
.tok.drag .disc{transform:scale(1.12);border-color:#fff}
.disc.empty{border-style:dashed;border-color:var(--mut);background:rgba(255,255,255,.03);color:var(--mut);font-weight:600;font-size:20px}
.disc svg{width:23px;height:23px;opacity:.9}
.disc.photo{background-size:cover;background-position:center 20%}
.disc.photo svg{display:none}
.disc .val{position:absolute;bottom:-6px;right:-6px;background:var(--lime);color:#0a0e0c;font-size:8px;font-weight:800;padding:1px 4px;border-radius:6px;border:1px solid #0a0e0c}
.role{margin-top:13px;font-family:'Bebas Neue';font-size:11px;letter-spacing:1px;color:var(--lime-dim);line-height:1}
.pname{margin-top:2px;font-size:10px;font-weight:700;max-width:74px;text-align:center;text-overflow:ellipsis;overflow:hidden;white-space:nowrap;text-shadow:0 1px 3px #000}
.psub{margin-top:1px;font-size:8.5px;font-weight:700;max-width:78px;text-align:center;color:#ffc46b;opacity:.92;text-overflow:ellipsis;overflow:hidden;white-space:nowrap;text-shadow:0 1px 3px #000}
.psub::before{content:'в–ё';font-size:7px;margin-right:2px;opacity:.7}
.flag{font-size:9px}
.disc .capt{position:absolute;top:-6px;left:-6px;width:15px;height:15px;border-radius:50%;background:var(--gold);color:#0a0e0c;font-size:9px;font-weight:800;display:grid;place-items:center;border:1.5px solid #0a0e0c}

/* ---------- Club emblem ---------- */
.emblem{
  flex:0 0 auto;width:22px;height:22px;border-radius:50%;
  display:inline-grid;place-items:center;
  font-family:'Bebas Neue';font-size:9px;letter-spacing:.3px;color:#fff;
  box-shadow:inset 0 0 0 1.5px rgba(255,255,255,.25);
}
.prow .nm .emblem{vertical-align:middle;margin-right:6px}

/* ---------- Bottom info ---------- */
.statbar{
  flex-shrink:0;display:flex;gap:8px;padding:6px 14px calc(env(safe-area-inset-bottom) + 12px);
  align-items:stretch;cursor:pointer;
}
.statbar:active{opacity:.85}
.statmore{flex:0 0 auto;display:grid;place-items:center;width:42px;border:1px solid var(--line);border-radius:13px;background:var(--panel);font-size:18px}
.stat{flex:1;background:var(--panel);border:1px solid var(--line);border-radius:13px;padding:8px 10px}
.stat .k{font-size:9px;letter-spacing:2px;color:var(--mut);text-transform:uppercase}
.stat .v{font-family:'Bebas Neue';font-size:22px;letter-spacing:1px;color:var(--lime);line-height:1}
.stat .v small{font-size:12px;color:var(--mut);font-family:'Manrope';font-weight:600}

/* ---------- Bench ---------- */
.bench{padding:2px 14px calc(env(safe-area-inset-bottom) + 30px)}
.bench .bh{display:flex;align-items:baseline;gap:9px;margin:8px 2px 11px}
.bench .bh b{font-family:'Bebas Neue';font-size:21px;letter-spacing:1.5px;color:var(--ink)}
.bench .bh span{font-size:11px;color:var(--mut)}
.bench .bh i{margin-left:auto;font-style:normal;font-size:10px;color:var(--lime-dim);letter-spacing:1px}
.bgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(92px,1fr));gap:9px}
.bcard{background:var(--panel);border:1px solid var(--line);border-radius:15px;padding:11px 7px 9px;display:flex;flex-direction:column;align-items:center;gap:5px;cursor:pointer;transition:.12s}
.bcard:active{transform:scale(.95);background:var(--panel2)}
.bav{width:46px;height:46px;border-radius:50%;background:linear-gradient(160deg,#1d2722,#10160f);border:2px solid var(--line);display:grid;place-items:center;color:var(--mut);overflow:hidden}
.bav svg{width:22px;height:22px;opacity:.85}
.bav.photo{background-size:cover;background-position:center 20%;border-color:var(--lime)}
.bav.photo svg{display:none}
.bcard .bn{font-size:11px;font-weight:800;text-align:center;white-space:nowrap;max-width:100%;overflow:hidden;text-overflow:ellipsis}
.bcard .bp{font-family:'Bebas Neue';font-size:12px;letter-spacing:.5px;color:var(--lime-dim);line-height:.9}
.bcard .bv{font-size:10px;color:var(--mut);font-weight:700}
.bcard[data-pid]{touch-action:none}
.bcard.dragging{opacity:.35}
.bcard.add{justify-content:center;border-style:dashed;border-color:var(--line);background:transparent;min-height:96px}
.bcard.add:active{background:rgba(255,255,255,.03)}
.bcard.add .addplus{font-size:28px;font-weight:800;line-height:1;color:var(--lime)}
.bcard.add .addlbl{font-size:10px;color:var(--mut);font-weight:700}
.benchghost{position:fixed;left:0;top:0;transform:translate(-50%,-50%);z-index:200;pointer-events:none;filter:drop-shadow(0 6px 14px rgba(0,0,0,.5))}
.tok.droptarget .disc{box-shadow:0 0 0 4px var(--lime),0 5px 14px rgba(0,0,0,.5)!important;border-color:#fff!important}
.benchfoot{display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:6px;color:var(--mut);font-size:12px;padding:12px 4px 6px}
.benchfoot b{color:var(--ink);font-family:'Bebas Neue';font-size:19px;letter-spacing:.5px;margin:0 1px}
.benchfoot small{font-size:10px;margin-left:1px}
.benchfoot span{font-size:11px;opacity:.85}
.benchEmpty{color:var(--mut);font-size:12px;padding:6px 4px 24px;line-height:1.8}
.scrollcue{text-align:center;color:var(--mut);font-size:10px;letter-spacing:2px;padding:2px 0 6px;opacity:.8}

/* ---------- Sheet / Modal ---------- */
.scrim{position:fixed;inset:0;background:rgba(0,0,0,.55);backdrop-filter:blur(3px);z-index:50;opacity:0;pointer-events:none;transition:.2s}
.scrim.on{opacity:1;pointer-events:auto}
.sheet{
  position:fixed;left:0;right:0;bottom:0;max-width:560px;margin:0 auto;z-index:60;
  background:var(--panel);border-radius:22px 22px 0 0;border-top:1px solid var(--line);
  transform:translateY(110%);transition:transform .28s cubic-bezier(.3,.9,.3,1);
  max-height:86dvh;display:flex;flex-direction:column;box-shadow:0 -16px 40px rgba(0,0,0,.5);
}
.sheet.on{transform:translateY(0)}
.sheet.expanded{max-height:96dvh}
#sheetBody{display:flex;flex-direction:column;min-height:0;flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch}
#sheetBody>h2,#sheetBody>.controls{flex:0 0 auto}
.grabzone{flex:0 0 auto;display:flex;justify-content:center;align-items:center;height:30px;cursor:grab;touch-action:none}
.grabzone:active{cursor:grabbing}
.grab{width:44px;height:5px;border-radius:3px;background:var(--line);transition:width .15s,background .15s}
.grabzone:active .grab,.sheet.expanded .grab{width:64px;background:var(--mut)}
.sheet h2{font-family:'Bebas Neue';font-size:24px;letter-spacing:1.5px;margin:4px 16px 8px;display:flex;align-items:center;gap:8px}
.sheet h2 span{font-size:11px;font-family:'Manrope';font-weight:700;color:var(--lime);background:rgba(202,255,58,.12);padding:3px 9px;border-radius:999px;margin-left:auto}

/* search + filters */
.controls{padding:0 16px 8px}
.search{
  width:100%;background:var(--panel2);border:1px solid var(--line);border-radius:12px;
  padding:11px 13px;color:var(--ink);font-size:15px;font-family:'Manrope';outline:none;
}
.search::placeholder{color:var(--mut)}
.filters{display:flex;gap:6px;overflow-x:auto;padding:9px 0 2px;scrollbar-width:none}
.filters::-webkit-scrollbar{display:none}
.fchip{flex:0 0 auto;padding:6px 11px;border-radius:999px;border:1px solid var(--line);background:var(--panel2);color:var(--mut);font-size:12px;font-weight:700;cursor:pointer;white-space:nowrap}
.fchip.on{background:var(--ink);color:#0a0e0c;border-color:var(--ink)}
.fchip.subchip.on{background:var(--lime);color:#0a0e0c;border-color:var(--lime)}
.filters .fchipdiv{flex:0 0 auto;width:1px;align-self:center;height:18px;background:var(--line);margin:0 5px}

/* list */
.list{overflow-y:auto;-webkit-overflow-scrolling:touch;touch-action:pan-y;overscroll-behavior:contain;padding:4px 12px calc(env(safe-area-inset-bottom) + 18px);flex:1;min-height:0}
.prow{
  display:flex;align-items:center;gap:11px;padding:9px 8px;border-radius:13px;cursor:pointer;transition:.12s;
}
.prow:active{background:var(--panel2)}
.prow .pos{flex:0 0 40px;text-align:center;font-family:'Bebas Neue';font-size:14px;letter-spacing:.5px;color:#0a0e0c;background:var(--lime);border-radius:8px;padding:5px 0}
.prow .pos.gk{background:var(--gold)}
.prow .pos.df{background:#4fc3f7}
.prow .pos.mf{background:#caff3a}
.prow .pos.fw{background:#ff8a65}
.prow .meta{flex:1;min-width:0}
.prow .nm{font-weight:800;font-size:15px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.prow .sub{font-size:11px;color:var(--mut);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.prow .price{font-family:'Bebas Neue';font-size:17px;color:var(--lime);letter-spacing:.5px}
.prow.inxi{opacity:.4}
.prow .badge{font-size:9px;color:var(--gold);font-weight:800}
.empty-msg{text-align:center;color:var(--mut);padding:40px 20px;font-size:13px}

/* action menu */
.menu{padding:6px 14px calc(env(safe-area-inset-bottom) + 16px)}
.mitem{display:flex;align-items:center;gap:12px;padding:15px 14px;border-radius:13px;font-weight:700;font-size:15px;cursor:pointer}
.mitem:active{background:var(--panel2)}
.mitem .mi{width:34px;height:34px;border-radius:10px;display:grid;place-items:center;background:var(--panel2);font-size:15px}
.mitem.danger{color:var(--red)}
.mitem.danger .mi{color:var(--red)}

/* detail */
.detail{padding:0 18px calc(env(safe-area-inset-bottom) + 20px)}
.dhead{display:flex;align-items:center;gap:14px;padding:6px 0 14px}
.davatar{width:62px;height:62px;border-radius:50%;background:linear-gradient(160deg,#1d2722,#10160f);border:2px solid var(--lime);display:grid;place-items:center;font-family:'Bebas Neue';font-size:24px;color:var(--lime);overflow:hidden}
.davatar.photo{background-size:cover;background-position:center 20%}
.davatar.photo svg{display:none}
.davatar svg{width:30px;height:30px}
.dname{font-family:'Bebas Neue';font-size:30px;letter-spacing:1px;line-height:.95}
.dclub{font-size:13px;color:var(--mut);font-weight:600;margin-top:3px}
.dgrid{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-top:4px}
.dcell{background:var(--panel2);border:1px solid var(--line);border-radius:13px;padding:11px 13px}
.dcell .dk{font-size:10px;letter-spacing:2px;color:var(--mut);text-transform:uppercase}
.dcell .dv{font-family:'Bebas Neue';font-size:23px;letter-spacing:1px;margin-top:2px}
.dcell.full{grid-column:1/3}
.dcell .dv.lime{color:var(--lime)}
.bigbtn{
  width:100%;margin-top:14px;padding:15px;border-radius:14px;border:0;cursor:pointer;
  font-family:'Bebas Neue';font-size:20px;letter-spacing:1.5px;background:var(--lime);color:#0a0e0c;
}
.bigbtn:active{transform:scale(.98)}
.bigbtn.ghost{background:transparent;color:var(--ink);border:1px solid var(--line)}

.toast{
  position:fixed;left:50%;bottom:96px;transform:translateX(-50%) translateY(20px);
  background:var(--ink);color:#0a0e0c;padding:11px 18px;border-radius:999px;font-weight:800;font-size:13px;
  z-index:90;opacity:0;transition:.25s;pointer-events:none;box-shadow:var(--shadow);max-width:90%;text-align:center;
}
.toast.on{opacity:1;transform:translateX(-50%) translateY(0)}
.hint{position:absolute;left:50%;top:46%;transform:translateX(-50%);text-align:center;color:rgba(255,255,255,.5);font-size:12px;pointer-events:none;width:80%}

/* ---------- Load more sentinel ---------- */
.loadmore{
  text-align:center;color:var(--mut);font-size:10px;letter-spacing:1.5px;
  padding:14px 8px 6px;opacity:.8;
}

/* ---------- Bench mode switcher ---------- */
.bench-badge{
  display:inline-flex;align-items:center;gap:5px;
  font-size:11px;color:var(--mut);font-weight:700;
  padding:2px 0;margin-bottom:4px;
}
.bench-badge b{color:var(--lime)}

/* ---------- Share preview ---------- */
.shareprev{border-radius:14px;overflow:hidden;border:1px solid var(--line);margin-bottom:10px;background:#000}
.shareprev img{display:block;width:100%;height:auto}
.sharecap{font-size:13px;color:var(--ink);line-height:1.5;margin:2px 2px 8px}
.sharelink{margin:0 2px 12px;overflow:hidden;white-space:nowrap}
.sharelink .sl{
  color:#4ea1ff;font-size:14px;font-weight:600;
  text-overflow:clip;          /* иҰӢеҲҮгӮҢгҒ•гҒӣгӮӢпјҲвҖҰгӮ’еҮәгҒ•гҒӘгҒ„пјү */
  display:inline-block;max-width:62%;overflow:hidden;white-space:nowrap;vertical-align:bottom;
}

/* ---------- Original team profile form ---------- */
.formfield{margin-bottom:11px}
.formfield label{display:block;font-size:11px;letter-spacing:1px;color:var(--mut);text-transform:uppercase;margin:0 2px 5px}
.formfield label i{font-style:normal;color:var(--lime-dim);margin-left:6px;letter-spacing:0;text-transform:none}
.colorrow{display:flex;gap:9px;flex-wrap:wrap;padding:2px}
.cdot2{width:30px;height:30px;border-radius:50%;cursor:pointer;box-shadow:inset 0 0 0 2px rgba(0,0,0,.25);transition:.12s}
.cdot2.on{box-shadow:0 0 0 3px var(--ink),inset 0 0 0 2px rgba(0,0,0,.25);transform:scale(1.08)}

/* ---------- Original team button ---------- */
.origbtn{
  display:flex;align-items:center;justify-content:center;gap:6px;
  padding:13px;border-radius:13px;margin-bottom:4px;cursor:pointer;
  font-weight:800;font-size:14px;color:#0a0e0c;
  background:linear-gradient(120deg,var(--lime),var(--lime-dim));
  box-shadow:0 4px 14px rgba(202,255,58,.22);
}
.origbtn:active{transform:scale(.98)}

</style>

<div class="app">
  <header>
    <div class="brand">
      <div class="logo">STARTING <b>XI</b></div>
      <div class="tag" id="teamTag">tactics board</div>
    </div>
    <div class="hbtn">
      <div class="icon" id="btnShare" title="е…ұжңү"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 17 20 12 15 7"/><path d="M4 19v-3a4 4 0 0 1 4-4h12"/></svg></div>
      <div class="icon" id="btnLoad" title="гӮҜгғ©гғ–иӘӯиҫј">в¬Ү</div>
      <div class="icon" id="btnMarket" title="з§»зұҚеёӮе ҙ">вҮ„</div>
      <div class="icon" id="btnReset" title="ж•ҙеҲ—гғӘгӮ»гғғгғҲ">вҹІ</div>
    </div>
  </header>

  <div class="fbar" id="fbar"></div>

  <div class="scroll" id="scroll">
    <div class="pitchwrap">
      <div class="pitch" id="pitch">
        <div class="markings">
          <div class="mk center-line"></div>
          <div class="mk center-circle"></div>
          <div class="mk spot"></div>
          <div class="mk box-top"></div>
          <div class="mk box-top-s"></div>
          <div class="mk box-bot"></div>
          <div class="mk box-bot-s"></div>
        </div>
        <div class="hint" id="hint">з©әгҒҚгҒ®в—ҜгӮ’гӮҝгғғгғ—гҒ—гҒҰйҒёжүӢгӮ’й…ҚзҪ® пјҸ й…ҚзҪ®еҫҢгҒҜгғүгғ©гғғгӮ°гҒ§еҫ®иӘҝж•ҙгғ»йҮҚгҒӯгӮӢгҒЁе…ҘгӮҢжӣҝгҒҲ</div>
      </div>
    </div>

    <div class="statbar" id="statbar" title="гӮҝгғғгғ—гҒ§и©ізҙ°еҲҶжһҗ">
      <div class="stat"><div class="k">Avg age</div><div class="v" id="sAge">вҖ“</div></div>
      <div class="stat"><div class="k">Players</div><div class="v" id="sCnt">0<small>/11</small></div></div>
      <div class="statmore">рҹ“Ҡ</div>
    </div>

